<!-- base.njk -->
<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta http-equiv="X-UA-Compatible" content="IE=edge" />
  <meta name="viewport" content="width=device-width, initial-scale=1, viewport-fit=cover">
  <meta name="google-site-verification" content="vKkP615NVTrbJknjA1ykKXOHT0VPbJqJgAO8VDea4pE" />
  <title>{{ title }}</title>
  <meta name="robots" content="noindex">
  
  <meta name="description"
    content="{{ metaDescription or eleventyComputed.metaDescription or metadata.description }}" />
  <meta name="keywords" content="{{ metaKeywords or eleventyComputed.metaKeywords or metaKeywords.description }}" />
  <style>
    :root {
      --c-primary:      {{ global.c_primary }};
      --c-secondary:    {{ global.c_secondary }};
      --bg-dark:        {{ global.bg_dark }};
      --c-bg-dark:      {{ global.c_bg_dark }};
      --bg-light:       {{ global.bg_light }};
      --c-bg-light:     {{ global.c_bg_light }};
      --btn-radius:     {{ global.btn_radius }};
      --padding-global: {{ global.padding_global }};
    }
  </style>
  <link rel="stylesheet" href="/assets/css/style.css" />
  <link rel="stylesheet" href="/assets/css/docs.css" />


  <link rel="stylesheet" href="https://hg5.netlify.app/output.css">
  <link rel="canonical" href="{{ global.url }}/{{ page.url | url }}" />
  <link rel="icon" href="/assets/static/images/favicon.ico" type="image/x-icon">
  <meta property="og:site_name" content="{{ global.empresa }}" />
  <meta property="og:image" content="{{ global.url }}/assets/static/images/1.jpg" />
  <meta property="og:title" content="{{ title }}" />
  <meta property="og:type" content="website" />
  <meta property="og:url" content="{{ global.url }}" />
  <meta property="og:description"
    content="{{ metaKeywords or eleventyComputed.metaKeywords or metaKeywords.description }}" />
  <!-- End Google Tag Manager -->
</head>
<body class="contain guide {% if page.url == '/' or page.url == '/about/' %}home{% endif %}">




  {% set breadcrumbs = [] %}


  {% if page_section != 'index' %}
  {% include '_website/nav.njk' %}


  <main class="main-widthsidebar">
    <div class="row smmax:reverse">
      <div class="col-xs-12 col-md-1"></div>
      <div class="col-xs-12 col-md-7">
        
        {{ content | safe }}
      </div>

      {% if content | toc | safe != 0 %}
      <div class="col-xs-12  col-md-4">
        {{ content | toc | safe }}
      </div>
    {% endif %}
    </div>
  </main>


  {% else %}
  <div class="row">
    <div class="col-xs-12">
      {{ content | safe }}
    </div>

  </div>
  {% endif %}
  <link rel="stylesheet" href="https://unpkg.com/aos@2.3.1/dist/aos.css" />
  <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/swiper@9/swiper-bundle.min.css" />

  <script src="https://code.jquery.com/jquery-3.4.1.min.js"></script>
  <script src="https://unpkg.com/aos@2.3.1/dist/aos.js"></script>
  <script src="https://cdn.jsdelivr.net/npm/swiper@9/swiper-bundle.min.js"></script>
  <script src="https://cdnjs.cloudflare.com/ajax/libs/gsap/3.10.4/gsap.min.js"></script>
  <script src="https://cdn.rawgit.com/zenorocha/clipboard.js/master/dist/clipboard.min.js"></script>
  <script src="https://cdn.jsdelivr.net/npm/interactjs/dist/interact.min.js"></script>
  <script src="/assets/js/index.js"></script>
  <script src="/assets/js/prism.js" type="module"></script>
  <script>AOS.init();</script>

  <script>
    var height;
    interact(".resize")
      .resizable({
        // resize from all edges and corners
        edges: {
          left: true,
          right: true,
          bottom: false,
          top: false,
        },
        modifiers: [
          // keep the edges inside the parent
          interact.modifiers.restrictEdges({
            outer: "parent",
          }),
          // minimum size
          interact.modifiers.restrictSize({
            min: { width: 320, height: 500 },
            max: { width: 1500, height: 500 },
          }),
        ],
        inertia: true,
      })
      .on("resizemove", function (event) {
        var target = event.target;
        event.target.classList.add("resize-overlay");
        var x = parseFloat(target.getAttribute("data-x")) || 0;
        var y = parseFloat(target.getAttribute("data-y")) || 0;
        // update the element's style
        target.style.width = event.rect.width + "px";
        target.style.webkitTransform = target.style.transform =
          "translate(" + x + "px," + y + "px)";
        target.setAttribute("data-x", x);
        target.setAttribute("data-y", y);
        target.querySelector(".resize-resolution").textContent =
          Math.round(event.rect.width) +
          "\u00D7" +
          Math.round(event.rect.height);
        if (event.rect.width < 320) {
          target.querySelector(".resize-media").textContent = "XS";
        } else if (event.rect.width < 768) {
          target.querySelector(".resize-media").textContent = "SM";
        } else if (event.rect.width < 992) {
          target.querySelector(".resize-media").textContent = "MD";
        } else if (event.rect.width < 1280) {
          target.querySelector(".resize-media").textContent = "LG";
        } else if (event.rect.width < 1500) {
          target.querySelector(".resize-media").textContent = "XL";
        } else {
          target.querySelector(".resize-media").textContent = "XL";
        }
      })
      .on("resizeend", function (event) {
        event.target.classList.remove("resize-overlay");
      });
    document.addEventListener("DOMContentLoaded", function () {
      // ── Dedent automático: elimina sangría común antes de resaltar ─
      document.querySelectorAll('pre code').forEach(code => {
        let lines = code.textContent.split('\n');
        // Eliminar líneas vacías al inicio y al final
        while (lines.length && !lines[0].trim()) lines.shift();
        while (lines.length && !lines[lines.length - 1].trim()) lines.pop();
        // Calcular la sangría mínima (ignorando líneas vacías)
        const minIndent = lines
          .filter(l => l.trim().length > 0)
          .reduce((min, l) => Math.min(min, l.match(/^(\s*)/)[1].length), Infinity);
        if (minIndent > 0 && isFinite(minIndent)) {
          lines = lines.map(l => l.slice(minIndent));
        }
        code.textContent = lines.join('\n');
      });
      // ──────────────────────────────────────────────────────────────

      Prism.highlightAll();

      // ── Code blocks con cabecera colapsable ───────────────────
      const LANG_LABELS = {
        html: 'HTML', css: 'CSS', scss: 'SCSS', js: 'JavaScript',
        javascript: 'JavaScript', ts: 'TypeScript', typescript: 'TypeScript',
        bash: 'Bash', shell: 'Shell', njk: 'Nunjucks', nunjucks: 'Nunjucks',
        json: 'JSON', python: 'Python', yaml: 'YAML', xml: 'XML',
        markup: 'HTML',
      };

      const SKIP_SELECTORS = [
        '.code-view', '.code-block-body',
        'table', '.sd-arch', '[contenteditable]'
      ].join(',');

      document.querySelectorAll('.guide pre').forEach(pre => {
        // Saltar si está dentro de un contexto que no debe tener cabecera
        if (pre.closest(SKIP_SELECTORS)) return;
        // Saltar si ya está envuelto
        if (pre.closest('.code-block-wrapper')) return;

        const code = pre.querySelector('code');
        if (!code) return;

        // Solo aplicar a bloques con clase language-* (del markdown)
        const langClass = [...code.classList].find(c => c.startsWith('language-'));
        if (!langClass) return;

        const langKey   = langClass.replace('language-', '');
        const langLabel = LANG_LABELS[langKey] || langKey.toUpperCase();

        // Crear wrapper
        const wrapper = document.createElement('div');
        wrapper.className = 'code-block-wrapper';

        // Crear cabecera
        const header = document.createElement('div');
        header.className = 'code-block-header';
        header.innerHTML = `
          <div class="code-block-dots">
            <span></span><span></span><span></span>
          </div>
          <span class="code-block-lang code-block-lang--${langKey}">${langLabel}</span>
          <div class="code-block-actions">
            <button class="code-block-btn code-block-copy" title="Copiar código">
              <svg viewBox="0 0 16 16" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M4 4v-1a2 2 0 0 1 2-2h6a2 2 0 0 1 2 2v8a2 2 0 0 1-2 2h-1"/><rect x="2" y="6" width="8" height="8" rx="1.5"/></svg>
            </button>
            <button class="code-block-btn code-block-toggle" title="Colapsar / Expandir">
              <svg class="code-block-toggle-icon" viewBox="0 0 16 16" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M4 6l4 4 4-4"/></svg>
            </button>
          </div>`;

        // Crear body contenedor
        const body = document.createElement('div');
        body.className = 'code-block-body';

        // Insertar en DOM antes de calcular alturas
        pre.parentNode.insertBefore(wrapper, pre);
        wrapper.appendChild(header);
        body.appendChild(pre);
        wrapper.appendChild(body);

        // Fijar altura real tras insertar en DOM
        body.style.maxHeight = pre.scrollHeight + 'px';

        // Colapsar / Expandir al clic en cabecera
        header.addEventListener('click', (e) => {
          if (e.target.closest('.code-block-copy')) return;
          const collapsed = wrapper.classList.toggle('is-collapsed');
          body.style.maxHeight = collapsed ? '0' : pre.scrollHeight + 'px';
          body.classList.toggle('is-collapsed', collapsed);
        });

        // Copiar código
        header.querySelector('.code-block-copy').addEventListener('click', (e) => {
          e.stopPropagation();
          const btn = e.currentTarget;
          navigator.clipboard.writeText(code.innerText).then(() => {
            btn.classList.add('copied');
            btn.innerHTML = `<svg viewBox="0 0 16 16" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M2 8l4 4 8-8"/></svg> Copiado`;
            setTimeout(() => {
              btn.classList.remove('copied');
              btn.innerHTML = `<svg viewBox="0 0 16 16" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M4 4v-1a2 2 0 0 1 2-2h6a2 2 0 0 1 2 2v8a2 2 0 0 1-2 2h-1"/><rect x="2" y="6" width="8" height="8" rx="1.5"/></svg>`;
            }, 2000);
          });
        });
      });
      // ─────────────────────────────────────────────────────────

      // ── code-view: toolbar interactivo ────────────────────────
      document.querySelectorAll('.code-view').forEach(cv => {
        // Evitar doble inicialización
        if (cv.closest('.code-view-wrapper')) return;

        // Wrapper
        const wrapper = document.createElement('div');
        wrapper.className = 'code-view-wrapper';
        cv.parentNode.insertBefore(wrapper, cv);
        wrapper.appendChild(cv);

        // Toolbar
        const toolbar = document.createElement('div');
        toolbar.className = 'code-view-toolbar';
        toolbar.innerHTML = `
          <span class="code-view-toolbar__label">Preview</span>
          <div class="code-view-toolbar__actions">
            <button class="cv-btn cv-btn--dark" title="Alternar modo oscuro">
              <svg viewBox="0 0 16 16"><path d="M8 1v2M8 13v2M1 8h2M13 8h2M3.05 3.05l1.41 1.41M11.54 11.54l1.41 1.41M3.05 12.95l1.41-1.41M11.54 4.46l1.41-1.41"/><circle cx="8" cy="8" r="3"/></svg>
              Dark
            </button>
            <div class="cv-separator"></div>
            <button class="cv-btn cv-btn--rtl" title="Alternar dirección RTL">
              <svg viewBox="0 0 16 16"><path d="M14 4H7M14 8H7M14 12H4"/><path d="M2 10l-2-2 2-2"/></svg>
              RTL
            </button>
            <div class="cv-separator"></div>
            <button class="cv-btn cv-btn--bg" title="Fondo blanco" data-mode="white">
              <svg viewBox="0 0 16 16"><rect x="2" y="2" width="12" height="12" rx="2"/></svg>
              BG
            </button>
          </div>`;

        wrapper.insertBefore(toolbar, cv);

        // Botón Dark
        toolbar.querySelector('.cv-btn--dark').addEventListener('click', function() {
          const isDark = cv.classList.toggle('bg-dark');
          cv.classList.toggle('has-light', !isDark);
          this.classList.toggle('is-active', isDark);
        });

        // Botón RTL
        toolbar.querySelector('.cv-btn--rtl').addEventListener('click', function() {
          const isRtl = cv.classList.toggle('is-rtl');
          cv.setAttribute('dir', isRtl ? 'rtl' : 'ltr');
          this.classList.toggle('is-active', isRtl);
        });

        // Botón BG (ciclo: checker → white → black)
        const bgBtn = toolbar.querySelector('.cv-btn--bg');
        const bgModes = ['checker', 'white', 'black'];
        let bgIdx = 0;
        bgBtn.addEventListener('click', function() {
          cv.classList.remove('cv-bg--white', 'cv-bg--black');
          bgIdx = (bgIdx + 1) % bgModes.length;
          const mode = bgModes[bgIdx];
          if (mode !== 'checker') cv.classList.add('cv-bg--' + mode);
          const labels = ['BG', 'BG ◻', 'BG ◼'];
          bgBtn.childNodes[bgBtn.childNodes.length - 1].textContent = ' ' + labels[bgIdx];
          bgBtn.classList.toggle('is-active', bgIdx !== 0);
        });
      });
      // ─────────────────────────────────────────────────────────
    });








  </script>

<script>

window.addEventListener('DOMContentLoaded', () => {
  const options = {
    root: null, // se refiere al viewport
    rootMargin: '0px 0px -80% 0px', // Solo la parte superior del elemento debe estar en el viewport
    threshold: 0 // 10% de la sección debe estar visible
  };

  const observer = new IntersectionObserver((entries, observer) => {
    entries.forEach(entry => {
      const id = entry.target.getAttribute('id');
      const navLink = document.querySelector(`nav.toc ol li a[href="#${id}"]`);
      if (entry.isIntersecting) {
        const currentlyActive = document.querySelector('nav.toc ol li a.active');
        if (currentlyActive) {
          currentlyActive.classList.remove('active');
        }
        navLink.classList.add('active');
      } else {
        navLink.classList.remove('active');
      }
    });
  }, options);

  // Observa cada sección que tiene un `id`
  document.querySelectorAll('.main-content [id]').forEach((section) => {
    observer.observe(section);
  });
});


  </script>




</body>
</html>