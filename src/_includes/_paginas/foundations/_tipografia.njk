---
layout: base.njk
---
<div class="container-fluid">
  {% include '_website/hero.njk' %}
</div>

<div class="main-content">

  {# ── Familias de fuente ─────────────────────────────────────── #}
  <div class="row pb-64">
    <div class="col-xs-12 mb-32">
      <div class="h2">Familias tipográficas</div>
    </div>
    <div class="col-xs-12">

      <div class="row mb-8 title-m ttu c-dark-grey">
        <div class="col-xs-3">Variable SCSS</div>
        <div class="col-xs-4">Font-face</div>
        <div class="col-xs-5">Muestra</div>
      </div>
      <div class="border-b2 mb-16"></div>

      <div class="row mb-16 pb-16 border-b2">
        <div class="col-xs-3 hg-body-m">$font-family-a-l</div>
        <div class="col-xs-4 hg-body-m c-dark-grey">suisse-light · Light</div>
        <div class="col-xs-5 font-light" style="font-size:16px">Massimo Dutti Aa Bb Cc</div>
      </div>
      <div class="row mb-16 pb-16 border-b2">
        <div class="col-xs-3 hg-body-m">$font-family-a-r</div>
        <div class="col-xs-4 hg-body-m c-dark-grey">suisse-regular · Regular</div>
        <div class="col-xs-5" style="font-size:16px">Massimo Dutti Aa Bb Cc</div>
      </div>
      <div class="row mb-16 pb-16 border-b2">
        <div class="col-xs-3 hg-body-m">$font-family-a-m / a-b</div>
        <div class="col-xs-4 hg-body-m c-dark-grey">suisse-medium · Medium</div>
        <div class="col-xs-5 bold" style="font-size:16px">Massimo Dutti Aa Bb Cc</div>
      </div>
      <div class="row mb-16 pb-16 border-b2">
        <div class="col-xs-3 hg-body-m">$font-family-a-sb</div>
        <div class="col-xs-4 hg-body-m c-dark-grey">suisse-semibold · SemiBold</div>
        <div class="col-xs-5 semibold" style="font-size:16px">Massimo Dutti Aa Bb Cc</div>
      </div>
      <div class="row mb-16 pb-16 border-b2">
        <div class="col-xs-3 hg-body-m">$font-family-b-m</div>
        <div class="col-xs-4 hg-body-m c-dark-grey">dutti-extended-bold</div>
        <div class="col-xs-5 bold3" style="font-size:16px">Massimo Dutti Aa Bb</div>
      </div>
      <div class="row mb-16 pb-16 border-b2">
        <div class="col-xs-3 hg-body-m">$font-family-c-r</div>
        <div class="col-xs-4 hg-body-m c-dark-grey">massimo-daily-regular · Serif</div>
        <div class="col-xs-5 regular3" style="font-size:16px">Massimo Dutti Aa Bb Cc</div>
      </div>

    </div>
  </div>

  <hr />

  {# ── Escala tipográfica ─────────────────────────────────────── #}
  <div class="row pt-64 pb-64">
    <div class="col-xs-12 mb-32">
      <div class="h2">Escala tipográfica</div>
      <p class="hg-body-m c-dark-grey mt-8">Clases generadas por <code>$minheaders</code> en <code>abstract/_setup.scss</code>. El interletrado se aplica globalmente desde <code>style.scss</code>.</p>
    </div>

    <div class="col-xs-12">

      {# Cabecera #}
      <div class="row mb-8 title-m ttu c-dark-grey" style="letter-spacing:.1em">
        <div class="col-xs-2">Clase</div>
        <div class="col-xs-1">Mobile</div>
        <div class="col-xs-1">Desktop</div>
        <div class="col-xs-1">LH</div>
        <div class="col-xs-2">Peso</div>
        <div class="col-xs-2">Tracking</div>
        <div class="col-xs-3">Muestra</div>
      </div>
      <div class="border-b2 mb-8"></div>

      {% for tipo in global.tipografias %}
      <div class="row mb-4 pb-8 border-b2" style="align-items:center">
        <div class="col-xs-2">
          <code style="font-size:11px;background:rgba(0,0,0,.04);padding:2px 6px;border-radius:3px">.{{tipo.name}}</code>
        </div>
        <div class="col-xs-1 hg-body-m c-dark-grey">{{tipo.xs}}</div>
        <div class="col-xs-1 hg-body-m c-dark-grey">{{tipo.lg}}</div>
        <div class="col-xs-1 hg-body-m c-dark-grey">{{tipo.line}}</div>
        <div class="col-xs-2 hg-body-m c-dark-grey">
          {% if tipo.weight == 'light' %}light
          {% elif tipo.weight == 'regular' %}regular
          {% elif tipo.weight == 'medium' %}medium
          {% elif tipo.weight == 'bold' %}bold
          {% elif tipo.weight == 'regular3' %}regular3 (serif)
          {% else %}{{tipo.weight}}
          {% endif %}
        </div>
        <div class="col-xs-2">
          {% if tipo.tracking == '0.04em' %}
            <span style="display:inline-block;font-size:9px;font-weight:700;font-family:monospace;padding:1px 5px;border-radius:4px;background:#e8f4fd;color:#1a5e99">0.04em</span>
          {% elif tipo.tracking == '0.16em' %}
            <span style="display:inline-block;font-size:9px;font-weight:700;font-family:monospace;padding:1px 5px;border-radius:4px;background:#f0fdf4;color:#1a7a3c">0.16em</span>
          {% else %}
            <span style="font-size:10px;color:#bbb">—</span>
          {% endif %}
        </div>
        <div class="col-xs-3 {{tipo.name}}">Massimo Dutti</div>
      </div>
      {% endfor %}

    </div>
  </div>

  <hr />

  {# ── Tamaños fijos ──────────────────────────────────────────── #}
  <div class="row pt-64 pb-64">
    <div class="col-xs-12 mb-32">
      <div class="h2">Tamaños fijos — $headersFixers</div>
      <p class="hg-body-m c-dark-grey mt-8">Clases con tamaño fijo (no responsive). Generadas por <code>$headersFixers</code>.</p>
    </div>

    <div class="col-xs-12">
      <div class="row mb-8 title-m ttu c-dark-grey" style="letter-spacing:.1em">
        <div class="col-xs-2">Clase</div>
        <div class="col-xs-2">Font-size</div>
        <div class="col-xs-2">Line-height</div>
        <div class="col-xs-6">Muestra</div>
      </div>
      <div class="border-b2 mb-8"></div>

      {% set fixers = [
        { "cls": "text-12-r", "size": "12px", "lh": "1" },
        { "cls": "text-14-r", "size": "14px", "lh": "1.5" },
        { "cls": "text-16-r", "size": "16px", "lh": "1.5" },
        { "cls": "text-18-r", "size": "18px", "lh": "1.5" },
        { "cls": "text-20-r", "size": "20px", "lh": "1.2" },
        { "cls": "text-24-r", "size": "24px", "lh": "1.2" },
        { "cls": "text-32-r", "size": "32px", "lh": "1.2" },
        { "cls": "text-40-r", "size": "40px", "lh": "1.2" }
      ] %}
      {% for f in fixers %}
      <div class="row pb-8 mb-4 border-b2" style="align-items:center">
        <div class="col-xs-2">
          <code style="font-size:11px;background:rgba(0,0,0,.04);padding:2px 6px;border-radius:3px">.{{f.cls}}</code>
        </div>
        <div class="col-xs-2 hg-body-m c-dark-grey">{{f.size}}</div>
        <div class="col-xs-2 hg-body-m c-dark-grey">{{f.lh}}</div>
        <div class="col-xs-6 {{f.cls}}">Massimo Dutti</div>
      </div>
      {% endfor %}

    </div>
  </div>

  <hr />

  {# ── Interletrado ───────────────────────────────────────────── #}
  <div class="row pt-64 pb-64">
    <div class="col-xs-12 mb-32">
      <div class="h2">Interletrado</div>
    </div>
    <div class="col-xs-6 mb-32">
      <div class="title-m mb-16" style="letter-spacing:.1em">0.04em — cuerpo de texto</div>
      <p class="hg-body-m c-dark-grey mb-16">.p-tag · .title-l · .text-m · .text-l · .title-s · .input · .hg-body-m · .hg-body-m-b · .form-input-label-2 label</p>
      <div style="letter-spacing:0.04em;font-size:12px;padding:16px;background:#f5f5f5;border-radius:6px">
        Massimo Dutti — texto de cuerpo a 0.04em de interletrado
      </div>
    </div>
    <div class="col-xs-6 mb-32">
      <div class="title-m mb-16" style="letter-spacing:.1em">0.16em — etiquetas TTU</div>
      <p class="hg-body-m c-dark-grey mb-16">.title-m · .label-m · .semantic</p>
      <div style="letter-spacing:0.16em;text-transform:uppercase;font-size:12px;padding:16px;background:#f5f5f5;border-radius:6px">
        Massimo Dutti — etiqueta a 0.16em
      </div>
    </div>
  </div>

  <hr />

  {# ── Grosores ───────────────────────────────────────────────── #}
  <div class="row pt-64 pb-64">
    <div class="col-xs-12 mb-32">
      <div class="h2">Grosores</div>
    </div>

    <div class="col-xs-6 mb-32">
      <p class="label-m mb-8">font-light</p>
      <div class="font-light title-l" style="font-size:18px">Lorem ipsum dolor sit amet consectetur adipisicing elit.</div>
    </div>
    <div class="col-xs-6 mb-32">
      <p class="label-m mb-8">font-regular</p>
      <div class="font-regular title-l" style="font-size:18px">Lorem ipsum dolor sit amet consectetur adipisicing elit.</div>
    </div>
    <div class="col-xs-6 mb-32">
      <p class="label-m mb-8">bold (→ suisse-medium)</p>
      <div class="bold title-l" style="font-size:18px">Lorem ipsum dolor sit amet consectetur adipisicing elit.</div>
    </div>
    <div class="col-xs-6 mb-32">
      <p class="label-m mb-8">semibold (→ suisse-semibold)</p>
      <div class="semibold title-l" style="font-size:18px">Lorem ipsum dolor sit amet consectetur adipisicing elit.</div>
    </div>
    <div class="col-xs-6 mb-32">
      <p class="label-m mb-8">bold3 (dutti-extended-bold)</p>
      <div class="bold3" style="font-size:18px">Lorem ipsum dolor sit amet consectetur adipisicing elit.</div>
    </div>
    <div class="col-xs-6 mb-32">
      <p class="label-m mb-8">regular3 (massimo-daily-regular)</p>
      <div class="regular3" style="font-size:18px">Lorem ipsum dolor sit amet consectetur adipisicing elit.</div>
    </div>
  </div>

  {{ content | safe }}

</div>
