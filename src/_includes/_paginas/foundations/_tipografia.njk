---
layout: base.njk
---

<style>
/* ── Familias ──────────────────────────────────────────────────── */
.tf-families {
  display: grid;
  grid-template-columns: repeat(3, 1fr);
  gap: 2px;
  margin: 32px 0;
  border: 1px solid #e0e0e0;
  border-radius: 10px;
  overflow: hidden;
}
.tf-family-card {
  background: #fff;
  padding: 32px 28px 24px;
  display: flex;
  flex-direction: column;
  gap: 16px;
  border-right: 1px solid #e0e0e0;
}
.tf-family-card:last-child { border-right: none; }
.tf-family-card__specimen {
  font-size: 64px;
  line-height: 1;
  letter-spacing: -.02em;
  color: #000;
}
.tf-family-card__name {
  font-size: 11px;
  font-weight: 700;
  text-transform: uppercase;
  letter-spacing: .12em;
  color: #999;
}
.tf-family-card__weights {
  display: flex;
  flex-wrap: wrap;
  gap: 4px;
  margin-top: auto;
}
.tf-family-card__weight-pill {
  font-size: 10px;
  font-family: monospace;
  padding: 2px 7px;
  background: #f0f0f0;
  border-radius: 20px;
  color: #555;
}
.tf-family-card__var {
  font-size: 10px;
  font-family: monospace;
  color: #aaa;
  margin-top: 4px;
}
.tf-family-card__glyphs {
  font-size: 13px;
  color: #aaa;
  letter-spacing: .04em;
  margin-top: 4px;
}

/* ── Escala tipográfica ────────────────────────────────────────── */
.tf-scale {
  margin: 32px 0;
  border: 1px solid #e0e0e0;
  border-radius: 10px;
  overflow: hidden;
}
.tf-scale__header {
  display: grid;
  grid-template-columns: 140px 1fr 120px;
  padding: 10px 20px;
  background: #f7f7f7;
  border-bottom: 1px solid #e0e0e0;
  font-size: 10px;
  font-weight: 700;
  text-transform: uppercase;
  letter-spacing: .1em;
  color: #aaa;
}
.tf-scale-row {
  display: grid;
  grid-template-columns: 140px 1fr 120px;
  padding: 16px 20px;
  border-bottom: 1px solid #f0f0f0;
  align-items: center;
  transition: background .15s;
}
.tf-scale-row:last-child { border-bottom: none; }
.tf-scale-row:hover { background: #fafafa; }
.tf-scale-row__meta { display: flex; flex-direction: column; gap: 4px; }
.tf-scale-row__code {
  font-family: monospace;
  font-size: 11px;
  font-weight: 700;
  color: #000;
  background: rgba(0,0,0,.05);
  padding: 2px 7px;
  border-radius: 4px;
  display: inline-block;
  margin-bottom: 4px;
}
.tf-scale-row__pills {
  display: flex;
  flex-wrap: wrap;
  gap: 4px;
}
.tf-pill {
  font-size: 9px;
  font-family: monospace;
  padding: 1px 5px;
  border-radius: 3px;
  line-height: 1.6;
}
.tf-pill--size  { background: #f0f0f0; color: #555; }
.tf-pill--lh    { background: #f0f0f0; color: #555; }
.tf-pill--w     { background: #000; color: #fff; }
.tf-pill--t4    { background: #dbeafe; color: #1d4ed8; font-weight: 700; }
.tf-pill--t16   { background: #dcfce7; color: #15803d; font-weight: 700; }

.tf-scale-row__preview {
  padding: 8px 0;
  color: #000;
}
.tf-scale-row__badges {
  display: flex;
  flex-direction: column;
  align-items: flex-end;
  gap: 4px;
}

/* ── Tamaños fijos ─────────────────────────────────────────────── */
.tf-fixers {
  margin: 32px 0;
}
.tf-fixer-row {
  display: flex;
  align-items: baseline;
  gap: 24px;
  padding: 12px 0;
  border-bottom: 1px solid #f0f0f0;
}
.tf-fixer-row:last-child { border-bottom: none; }
.tf-fixer-row__meta {
  flex: 0 0 200px;
  display: flex;
  flex-direction: column;
  gap: 3px;
}
.tf-fixer-row__code {
  font-family: monospace;
  font-size: 11px;
  font-weight: 700;
  color: #000;
  background: rgba(0,0,0,.05);
  padding: 2px 7px;
  border-radius: 4px;
  display: inline-block;
}
.tf-fixer-row__info { font-size: 10px; color: #aaa; font-family: monospace; }
.tf-fixer-row__text { color: #000; }

/* ── Tracking ──────────────────────────────────────────────────── */
.tf-tracking {
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 2px;
  margin: 32px 0;
  border: 1px solid #e0e0e0;
  border-radius: 10px;
  overflow: hidden;
}
.tf-tracking-card {
  padding: 32px;
  background: #fff;
}
.tf-tracking-card:first-child { border-right: 1px solid #e0e0e0; }
.tf-tracking-card__label {
  font-size: 10px;
  font-weight: 700;
  text-transform: uppercase;
  letter-spacing: .1em;
  color: #aaa;
  margin-bottom: 8px;
}
.tf-tracking-card__val {
  font-size: 40px;
  font-weight: 700;
  font-family: monospace;
  line-height: 1;
  margin-bottom: 16px;
}
.tf-tracking-card--4  .tf-tracking-card__val { color: #1d4ed8; }
.tf-tracking-card--16 .tf-tracking-card__val { color: #15803d; }
.tf-tracking-card__demo {
  padding: 20px;
  background: #f7f7f7;
  border-radius: 6px;
  font-size: 14px;
  color: #000;
  margin: 20px 0;
  line-height: 1.6;
}
.tf-tracking-card__classes {
  display: flex;
  flex-wrap: wrap;
  gap: 4px;
}
.tf-tracking-card__cls {
  font-size: 10px;
  font-family: monospace;
  background: rgba(0,0,0,.05);
  padding: 2px 6px;
  border-radius: 3px;
  color: #555;
}

/* ── Grosores ──────────────────────────────────────────────────── */
.tf-weights {
  margin: 32px 0;
}
.tf-weight-row {
  display: grid;
  grid-template-columns: 180px 1fr;
  gap: 24px;
  padding: 20px 0;
  border-bottom: 1px solid #f0f0f0;
  align-items: center;
}
.tf-weight-row:last-child { border-bottom: none; }
.tf-weight-row__meta { display: flex; flex-direction: column; gap: 4px; }
.tf-weight-row__name { font-size: 13px; font-weight: 700; }
.tf-weight-row__face { font-size: 11px; color: #999; font-family: monospace; }
.tf-weight-row__var  { font-size: 10px; color: #bbb; font-family: monospace; }
.tf-weight-row__text { font-size: 22px; line-height: 1.2; }

/* ── Sección heading ───────────────────────────────────────────── */
.tf-section-title {
  font-size: 11px;
  font-weight: 700;
  text-transform: uppercase;
  letter-spacing: .12em;
  color: #aaa;
  margin-bottom: 8px;
}
.tf-section-h2 {
  font-size: 28px;
  font-weight: 700;
  line-height: 1.1;
  margin-bottom: 8px;
}
.tf-section-desc {
  font-size: 13px;
  color: #777;
  line-height: 1.5;
  margin-bottom: 0;
}
code {
  font-family: monospace;
  font-size: .9em;
  background: rgba(0,0,0,.05);
  padding: .1em .4em;
  border-radius: 3px;
}
</style>

<div class="container-fluid">
  {% include '_website/hero.njk' %}
</div>

<div class="main-content">

  {# ═══════════════════════════════════════════════════════════════
     1. FAMILIAS TIPOGRÁFICAS
  ══════════════════════════════════════════════════════════════ #}
  <div class="row pb-64">
    <div class="col-xs-12 mb-32">
      <p class="tf-section-title">Sistema tipográfico</p>
      <h2 class="tf-section-h2">Familias de fuentes</h2>
      <p class="tf-section-desc">Familias del sistema cargadas por holygrail5. Se acceden a través de los tokens CSS <code>--hg-typo-font-family-*</code>. La primaria es <strong>Suisse Intl</strong> (thin/light/regular/semibold), la secundaria <strong>Suisse Medium</strong> y la monoespaciada <strong>Suisse Intl Mono</strong>.</p>
    </div>
    <div class="col-xs-12">
      <div class="tf-families">

        <div class="tf-family-card">
          <div class="tf-family-card__name">Primary — Suisse Intl</div>
          <div class="tf-family-card__specimen" style="font-family:var(--hg-typo-font-family-primary-regular)">Aa</div>
          <div class="tf-family-card__glyphs" style="font-family:var(--hg-typo-font-family-primary-regular)">ABCDEFGHIJKLM abcdefghijklm 0123456789</div>
          <div class="tf-family-card__weights">
            <span class="tf-family-card__weight-pill" style="font-family:var(--hg-typo-font-family-primary-thin)">Thin 100</span>
            <span class="tf-family-card__weight-pill" style="font-family:var(--hg-typo-font-family-primary-light)">Light 300</span>
            <span class="tf-family-card__weight-pill" style="font-family:var(--hg-typo-font-family-primary-regular)">Regular 400</span>
            <span class="tf-family-card__weight-pill" style="font-family:var(--hg-typo-font-family-primary-bold)">SemiBold 600</span>
          </div>
          <div class="tf-family-card__var">--hg-typo-font-family-primary-thin / -light / -regular / -bold</div>
        </div>

        <div class="tf-family-card">
          <div class="tf-family-card__name">Secondary — Suisse Medium</div>
          <div class="tf-family-card__specimen" style="font-family:var(--hg-typo-font-family-secondary)">Aa</div>
          <div class="tf-family-card__glyphs" style="font-family:var(--hg-typo-font-family-secondary)">ABCDEFGHIJKLM abcdefghijklm</div>
          <div class="tf-family-card__weights">
            <span class="tf-family-card__weight-pill" style="font-family:var(--hg-typo-font-family-secondary)">Medium 500</span>
          </div>
          <div class="tf-family-card__var">--hg-typo-font-family-secondary</div>
        </div>

        <div class="tf-family-card">
          <div class="tf-family-card__name">Mono — Suisse Intl Mono</div>
          <div class="tf-family-card__specimen" style="font-family:var(--hg-typo-font-family-mono-regular)">Aa</div>
          <div class="tf-family-card__glyphs" style="font-family:var(--hg-typo-font-family-mono-regular)">ABCDEFGHIJKLM abcdefghijklm</div>
          <div class="tf-family-card__weights">
            <span class="tf-family-card__weight-pill" style="font-family:var(--hg-typo-font-family-mono-regular)">Regular 400</span>
            <span class="tf-family-card__weight-pill" style="font-family:var(--hg-typo-font-family-mono-bold)">Bold 700</span>
          </div>
          <div class="tf-family-card__var">--hg-typo-font-family-mono-regular / -mono-bold</div>
        </div>

      </div>
    </div>
  </div>

  {# ═══════════════════════════════════════════════════════════════
     2. ESCALA TIPOGRÁFICA
  ══════════════════════════════════════════════════════════════ #}
  <div class="row pt-64 pb-64">
    <div class="col-xs-12 mb-32">
      <p class="tf-section-title">$minheaders</p>
      <h2 class="tf-section-h2">Escala tipográfica</h2>
      <p class="tf-section-desc">Clases generadas por el mixin <code>typesMin()</code> a partir del mapa <code>$minheaders</code> en <code>abstract/_setup.scss</code>. Cada clase es responsive: tiene un tamaño para mobile y otro para desktop.</p>
    </div>
    <div class="col-xs-12">
      <div class="tf-scale">
        <div class="tf-scale__header">
          <span>Clase</span>
          <span>Preview</span>
          <span style="text-align:right">Propiedades</span>
        </div>
        {% for tipo in global.tipografias %}
        <div class="tf-scale-row">
          <div class="tf-scale-row__meta">
            <span class="tf-scale-row__code">.{{tipo.name}}</span>
            <div class="tf-scale-row__pills">
              <span class="tf-pill tf-pill--size">{{tipo.xs}} → {{tipo.lg}}</span>
              <span class="tf-pill tf-pill--lh">lh {{tipo.line}}</span>
              <span class="tf-pill tf-pill--w">{{tipo.weight}}</span>
              {% if tipo.tracking == '0.04em' %}
                <span class="tf-pill tf-pill--t4">0.04em</span>
              {% elif tipo.tracking == '0.16em' %}
                <span class="tf-pill tf-pill--t16">0.16em</span>
              {% endif %}
            </div>
          </div>
          <div class="tf-scale-row__preview {{tipo.name}}">
            Massimo Dutti — The Art of Elegance
          </div>
          <div class="tf-scale-row__badges">
            {% if tipo.tracking == '0.04em' %}
              <span style="font-size:9px;font-family:monospace;padding:1px 5px;border-radius:3px;background:#dbeafe;color:#1d4ed8;font-weight:700">tracking</span>
            {% elif tipo.tracking == '0.16em' %}
              <span style="font-size:9px;font-family:monospace;padding:1px 5px;border-radius:3px;background:#dcfce7;color:#15803d;font-weight:700">tracking</span>
            {% endif %}
          </div>
        </div>
        {% endfor %}
      </div>
    </div>
  </div>

  {# ═══════════════════════════════════════════════════════════════
     3. TAMAÑOS FIJOS
  ══════════════════════════════════════════════════════════════ #}
  <div class="row pt-64 pb-64">
    <div class="col-xs-12 mb-32">
      <p class="tf-section-title">$headersFixers</p>
      <h2 class="tf-section-h2">Tamaños fijos</h2>
      <p class="tf-section-desc">Clases con tamaño de fuente fijo (no responsive). Útiles para UI específica donde se necesita consistencia independientemente del breakpoint.</p>
    </div>
    <div class="col-xs-12">
      <div class="tf-fixers">
        {% set fixers = [
          { "cls": "text-40-r", "size": "40px", "lh": "1.2" },
          { "cls": "text-32-r", "size": "32px", "lh": "1.2" },
          { "cls": "text-24-r", "size": "24px", "lh": "1.2" },
          { "cls": "text-20-r", "size": "20px", "lh": "1.2" },
          { "cls": "text-18-r", "size": "18px", "lh": "1.5" },
          { "cls": "text-16-r", "size": "16px", "lh": "1.5" },
          { "cls": "text-14-r", "size": "14px", "lh": "1.5" },
          { "cls": "text-12-r", "size": "12px", "lh": "1" }
        ] %}
        {% for f in fixers %}
        <div class="tf-fixer-row">
          <div class="tf-fixer-row__meta">
            <span class="tf-fixer-row__code">.{{f.cls}}</span>
            <span class="tf-fixer-row__info">{{f.size}} / lh {{f.lh}}</span>
          </div>
          <div class="tf-fixer-row__text {{f.cls}}">Massimo Dutti</div>
        </div>
        {% endfor %}
      </div>
    </div>
  </div>

  {# ═══════════════════════════════════════════════════════════════
     4. INTERLETRADO
  ══════════════════════════════════════════════════════════════ #}
  <div class="row pt-64 pb-64">
    <div class="col-xs-12 mb-32">
      <p class="tf-section-title">style.scss</p>
      <h2 class="tf-section-h2">Interletrado</h2>
      <p class="tf-section-desc">El sistema define dos valores de <code>letter-spacing</code> aplicados globalmente a grupos de clases. No son opcionales: están forzados en <code>style.scss</code>.</p>
    </div>
    <div class="col-xs-12">
      <div class="tf-tracking">

        <div class="tf-tracking-card tf-tracking-card--4">
          <div class="tf-tracking-card__label">Cuerpo de texto</div>
          <div class="tf-tracking-card__val">0.04em</div>
          <div class="tf-tracking-card__demo" style="letter-spacing:0.04em">
            Massimo Dutti — The Art of Elegance. Texto de cuerpo con tracking ajustado para máxima legibilidad en tamaños pequeños.
          </div>
          <div class="tf-tracking-card__classes">
            <span class="tf-tracking-card__cls">.p-tag</span>
            <span class="tf-tracking-card__cls">.title-l</span>
            <span class="tf-tracking-card__cls">.text-m</span>
            <span class="tf-tracking-card__cls">.text-l</span>
            <span class="tf-tracking-card__cls">.title-s</span>
            <span class="tf-tracking-card__cls">.input</span>
            <span class="tf-tracking-card__cls">.hg-body-m</span>
            <span class="tf-tracking-card__cls">.hg-body-m-b</span>
            <span class="tf-tracking-card__cls">.form-input-label-2 label</span>
          </div>
        </div>

        <div class="tf-tracking-card tf-tracking-card--16">
          <div class="tf-tracking-card__label">Etiquetas TTU</div>
          <div class="tf-tracking-card__val">0.16em</div>
          <div class="tf-tracking-card__demo" style="letter-spacing:0.16em;text-transform:uppercase">
            Massimo Dutti — New Collection — Spring 2026
          </div>
          <div class="tf-tracking-card__classes">
            <span class="tf-tracking-card__cls">.title-m</span>
            <span class="tf-tracking-card__cls">.label-m</span>
            <span class="tf-tracking-card__cls">.semantic</span>
          </div>
        </div>

      </div>
    </div>
  </div>

  {# ═══════════════════════════════════════════════════════════════
     5. GROSORES
  ══════════════════════════════════════════════════════════════ #}
  <div class="row pt-64 pb-64">
    <div class="col-xs-12 mb-32">
      <p class="tf-section-title">Font weights</p>
      <h2 class="tf-section-h2">Grosores</h2>
      <p class="tf-section-desc">Cada peso es una familia <code>@font-face</code> independiente, expuesta como token <code>--hg-typo-font-family-*</code>. El "bold" del sistema (<code>primary-bold</code>) es <strong>suisse-semibold (600)</strong>; <code>secondary</code> es suisse-medium (500).</p>
    </div>
    <div class="col-xs-12">
      <div class="tf-weights">

        <div class="tf-weight-row">
          <div class="tf-weight-row__meta">
            <span class="tf-weight-row__name">primary-thin</span>
            <span class="tf-weight-row__face">suisse-thin</span>
            <span class="tf-weight-row__var">--hg-typo-font-family-primary-thin · 100</span>
          </div>
          <div class="tf-weight-row__text" style="font-family:var(--hg-typo-font-family-primary-thin)">Massimo Dutti — The Art of Elegance</div>
        </div>

        <div class="tf-weight-row">
          <div class="tf-weight-row__meta">
            <span class="tf-weight-row__name">primary-light</span>
            <span class="tf-weight-row__face">suisse-light</span>
            <span class="tf-weight-row__var">--hg-typo-font-family-primary-light · 300</span>
          </div>
          <div class="tf-weight-row__text" style="font-family:var(--hg-typo-font-family-primary-light)">Massimo Dutti — The Art of Elegance</div>
        </div>

        <div class="tf-weight-row">
          <div class="tf-weight-row__meta">
            <span class="tf-weight-row__name">primary-regular</span>
            <span class="tf-weight-row__face">suisse-regular</span>
            <span class="tf-weight-row__var">--hg-typo-font-family-primary-regular · 400</span>
          </div>
          <div class="tf-weight-row__text" style="font-family:var(--hg-typo-font-family-primary-regular)">Massimo Dutti — The Art of Elegance</div>
        </div>

        <div class="tf-weight-row">
          <div class="tf-weight-row__meta">
            <span class="tf-weight-row__name">secondary</span>
            <span class="tf-weight-row__face">suisse-medium</span>
            <span class="tf-weight-row__var">--hg-typo-font-family-secondary · 500</span>
          </div>
          <div class="tf-weight-row__text" style="font-family:var(--hg-typo-font-family-secondary)">Massimo Dutti — The Art of Elegance</div>
        </div>

        <div class="tf-weight-row">
          <div class="tf-weight-row__meta">
            <span class="tf-weight-row__name">primary-bold</span>
            <span class="tf-weight-row__face">suisse-semibold</span>
            <span class="tf-weight-row__var">--hg-typo-font-family-primary-bold · 600</span>
          </div>
          <div class="tf-weight-row__text" style="font-family:var(--hg-typo-font-family-primary-bold)">Massimo Dutti — The Art of Elegance</div>
        </div>

        <div class="tf-weight-row">
          <div class="tf-weight-row__meta">
            <span class="tf-weight-row__name">mono-regular</span>
            <span class="tf-weight-row__face">suisse-mono-regular</span>
            <span class="tf-weight-row__var">--hg-typo-font-family-mono-regular · 400</span>
          </div>
          <div class="tf-weight-row__text" style="font-family:var(--hg-typo-font-family-mono-regular)">Massimo Dutti — The Art of Elegance</div>
        </div>

        <div class="tf-weight-row">
          <div class="tf-weight-row__meta">
            <span class="tf-weight-row__name">mono-bold</span>
            <span class="tf-weight-row__face">suisse-mono-bold</span>
            <span class="tf-weight-row__var">--hg-typo-font-family-mono-bold · 700</span>
          </div>
          <div class="tf-weight-row__text" style="font-family:var(--hg-typo-font-family-mono-bold)">Massimo Dutti — The Art of Elegance</div>
        </div>

      </div>
    </div>
  </div>

  {{ content | safe }}

</div>
