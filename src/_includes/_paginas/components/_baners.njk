---
layout: base.njk
---
{% import "_macros/_token.njk" as tokens %}
{% import "_macros/_insert.njk" as insert %}
<div class="container-fluid">
  {% include '_website/hero.njk' %}
</div>
<div class="main-content innermarkdown ">  {{ content | safe }}
<div class="row">
  <div class="col-xs-12">
    <h2 id="banner-basic">BANNER-BASIC</h2>

  </div>
</div>


  <div class="row ">


    <div class="col-xs-12 grid-3 gap-16">
      <div class="mb-32 p-16 text-l text-center bg-warning"> <b>.bg-warning </b><br>
        Nullam justo eros, tincidunt sed aliquam at, venenatis eget ipsum. Mauris iaculis ac libero non consectetur.
      </div>
      
         <div class="mb-32 p-16 text-l text-center bg-info">  .bg-info <br>
        Nullam justo eros, tincidunt sed aliquam at, venenatis eget ipsum. Mauris iaculis ac libero non consectetur.
      </div>
      
