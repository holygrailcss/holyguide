<script src="https://cdnjs.cloudflare.com/ajax/libs/gsap/3.12.2/gsap.min.js"></script>
<script>
(() => {
  if (typeof gsap === 'undefined') return;

  const row     = document.getElementById('hg-home-row-cols');
  const prevBtn = document.getElementById('hg-home-nav-prev');
  const nextBtn = document.getElementById('hg-home-nav-next');
  const dragWrap = document.getElementById('hg-home-drag-wrap');

  if (!row || !prevBtn || !nextBtn) return;

  const NAV_BTN_OFFSET_MOBILE = -102;
  const NAV_BTN_OFFSET_DESKTOP = 102;
  const NAV_BTN_BREAKPOINT = 768;

  function positionNavBtns() {
    const desktop = window.innerWidth >= NAV_BTN_BREAKPOINT;
    const W = prevBtn.offsetWidth  || window.innerWidth * 0.15;
    const H = prevBtn.offsetHeight || 50;
    const adjust = (W - H) / 2;
    // En mobile: valor fijo directo (sin compensar adjust)
    // En desktop: compensa la rotación para que el borde visual quede a NAV_BTN_OFFSET_DESKTOP
    const leftVal  = desktop ? NAV_BTN_OFFSET_DESKTOP - adjust - 8    : NAV_BTN_OFFSET_MOBILE;
    const rightVal = desktop ? NAV_BTN_OFFSET_DESKTOP - adjust - 13   : NAV_BTN_OFFSET_MOBILE;
    gsap.set(prevBtn, { left: leftVal,  yPercent: -50, rotation: -90, transformOrigin: 'center center', overwrite: 'auto' });
    gsap.set(nextBtn, { right: rightVal, yPercent: -50, rotation: -90, transformOrigin: 'center center', overwrite: 'auto' });
  }
  requestAnimationFrame(positionNavBtns);

  document.body.dataset.activeCol = row.dataset.active || '0';

  const cols      = [...row.querySelectorAll('.hg-home-row-cols__col')];
  const totalCols = cols.length;
  let active = -1;
  let updateFooterInView = function() {};
  let btnsHidden = false;

  const COL_NAMES = [
    'New Season',
    'Editorials',
    'Archive',
    'About',
    'Contact',
    'NW 2026 Campaign',
  ];

  const SVG_PREV = `<svg width="16" height="16" viewBox="0 0 16 16" fill="none" xmlns="http://www.w3.org/2000/svg"><path d="M9.12598 12.832L4.83105 8L9.12598 3.16797L9.87402 3.83203L6.16992 8L9.87402 12.168L9.12598 12.832Z" fill="currentColor"/></svg>`;
  const SVG_NEXT = `<svg width="16" height="16" viewBox="0 0 16 16" fill="none" xmlns="http://www.w3.org/2000/svg"><path d="M5.5791 12.832L9.87402 8L5.5791 3.16797L4.83105 3.83203L8.53516 8L4.83106 12.168L5.5791 12.832Z" fill="currentColor"/></svg>`;
  prevBtn.innerHTML = '';
  nextBtn.innerHTML = '';
  cols.forEach((_, i) => {
    const label = COL_NAMES[i] || `Section ${i + 1}`;
    prevBtn.insertAdjacentHTML('beforeend',
      `<div class="hg-home-nav-btn__text label-m ttu"><div class="hg-home-nav-btn__chevron" aria-hidden="true">${SVG_PREV}</div><div>${label}</div><div></div></div>`);
    nextBtn.insertAdjacentHTML('beforeend',
      `<div class="hg-home-nav-btn__text label-m ttu"><div class="hg-home-nav-btn__chevron" aria-hidden="true">${SVG_NEXT}</div><div>${label}</div><div></div></div>`);
  });

  const colWidth       = () => window.innerWidth;
  const BREAKPOINT     = 992;
  const PEEK_CUTOUT    = 180;
  const PEEK_FULL      = 70;
  const SCALE_INACTIVE = 2 / 3;

  const isDesktop = () => window.innerWidth >= BREAKPOINT;

  const getPeek = (col) => col?.classList?.contains('hg-home-special-cutout') ? PEEK_CUTOUT : PEEK_FULL;

  // Devuelve la posición X de reposo de la columna i.
  // Desktop: activa → 0, adyacentes → asoman PEEK px, resto → escalonadas fuera.
  // Mobile: escalonadas por distancia (d * W) para que solo la inmediata entre al arrastrar.
  function getNaturalX(i) {
    const W = colWidth(), d = i - active;
    if (d === 0) return 0;
    if (isDesktop()) {
      const peek = getPeek(cols[i]);
      if (d === -1) return -(W - peek);
      if (d ===  1) return  (W - peek);
    }
    // Cada columna se aleja d * W: la columna 2 está en 2W, la 3 en 3W…
    // Con delta máximo de ±W (un ancho de pantalla) solo la adyacente (d=±1) puede entrar.
    return d * W;
  }

  // Devuelve la escala de reposo: 1 si es la activa, reducida si es inactiva.
  function getNaturalScale(i) { return i === active ? 1 : SCALE_INACTIVE; }

  // Devuelve el origen del transform según la posición relativa a la activa,
  // para que las adyacentes escalen desde el borde que toca a la activa.
  function getNaturalOrigin(i) {
    const d = i - active;
    if (d === -1) return 'right center';
    if (d ===  1) return 'left center';
    return 'center center';
  }

  const prevTexts = [...prevBtn.querySelectorAll('.hg-home-nav-btn__text')];
  const nextTexts = [...nextBtn.querySelectorAll('.hg-home-nav-btn__text')];
  let prevVis = -1, nextVis = -1;

  // Anima el texto de los botones prev/next para mostrar el nombre de la sección
  // hacia la que se va a navegar. El sentido del slide depende de la dirección del cambio.
  function updateNavLabels(newIndex, direction) {
    const fromY = direction >= 0 ?  120 : -120;
    const toY   = direction >= 0 ? -120 :  120;
    const DUR   = 0.35;

    const slide = (texts, targetIdx, curIdx) => {
      if (curIdx >= 0 && curIdx < texts.length) {
        gsap.to(texts[curIdx], { opacity: 0, y: toY, duration: DUR, ease: 'power2.in' });
      }
      if (targetIdx >= 0 && targetIdx < texts.length) {
        gsap.fromTo(texts[targetIdx],
          { opacity: 0, y: fromY },
          { opacity: 1, y: 0,    duration: DUR, ease: 'power2.out' }
        );
      }
      return targetIdx;
    };

    prevVis = slide(prevTexts, newIndex - 1, prevVis);
    nextVis = slide(nextTexts, newIndex + 1, nextVis);
  }

  // Reposiciona el scroll de una columna inactiva al abandonarla:
  // si el primer slide es el más visible sube al top; si es otro, lo centra en pantalla.
  // Se llama al inicio del drag para que la columna quede bien cuando se vuelva a ella.
  function scrollActiveToTopLink(col) {
    const links = [...col.querySelectorAll('.hg-home-box-link')];
    if (!links.length) return;

    let closest = null, maxVisible = -1;
    const vh = window.innerHeight;
    links.forEach(link => {
      const r = link.getBoundingClientRect();
      const visible = Math.max(0, Math.min(r.bottom, vh) - Math.max(r.top, 0));
      if (visible > maxVisible) { maxVisible = visible; closest = link; }
    });
    if (!closest) return;

    const isFirst   = closest === links[0];
    const colRect   = col.getBoundingClientRect();
    const linkRect  = closest.getBoundingClientRect();
    const maxScroll = col.scrollHeight - col.clientHeight;

    let raw;
    if (isFirst) {
      raw = 0;
    } else {
      const centerOffset = (col.clientHeight - closest.offsetHeight) / 2;
      raw = col.scrollTop + (linkRect.top - colRect.top) - centerOffset;
    }

    const target = Math.max(0, Math.min(raw, maxScroll));
    if (Math.abs(target - col.scrollTop) < 2) return;
    gsap.to(col, { scrollTop: target, duration: 0.3, ease: 'power2.out' });
  }

  let revealDone = false;

  // Activa la columna indicada: la mueve al centro, escala las adyacentes,
  // actualiza estado y botones, y dispara el reposicionamiento de la columna saliente.
  function setActive(index) {
    if (index < 0 || index >= totalCols) return;
    const direction  = index > active ? 1 : -1;
    const prevActive = active;
    active = index;

    row.dataset.active = String(active);
    document.body.dataset.activeCol = String(active);
    cols.forEach((col, i) => col.classList.toggle('is-active', i === active));

    if (prevActive >= 0 && prevActive !== active) {
      scrollActiveToTopLink(cols[prevActive]);
    }

    cols.forEach((col, i) => {
      const d = i - active;
      const tweenProps = {
        x:               getNaturalX(i),
        scale:           getNaturalScale(i),
        transformOrigin: getNaturalOrigin(i),
        zIndex:          d === 0 ? 1000 : 100,
        pointerEvents:   d === 0 ? 'auto' : 'none',
        duration:        0.5,
        ease:            'power3.out'
      };
      if (revealDone || d === 0) tweenProps.opacity = 1;
      gsap.to(col, tweenProps);
    });

    prevBtn.disabled = active === 0;
    nextBtn.disabled = active === totalCols - 1;
    updateFooterInView();

    if (index !== prevActive) updateNavLabels(active, direction);
  }

  prevBtn.addEventListener('click', () => setActive(active - 1));
  nextBtn.addEventListener('click', () => setActive(active + 1));

  let resizeT = null;
  window.addEventListener('resize', () => {
    clearTimeout(resizeT);
    // requestAnimationFrame garantiza que el layout está recalculado antes de leer offsetWidth
    requestAnimationFrame(positionNavBtns);
    resizeT = setTimeout(() => { setActive(active); resizeT = null; }, 100);
  });

  // Drag / swipe horizontal: pointer en desktop; touch en móvil (más fiable que solo pointer en iOS).
  // touch-action en CSS: wrapper none + columnas pan-y + herencia a hijos.
  function initDrag() {
    if (!dragWrap) return;

    const SWIPE_PX      = 70;
    const DRAG_START_PX = 8;

    let isDragging = false, started = false;
    let startX = 0, startY = 0;
    let lastClientX = 0, lastClientY = 0;
    let lastDragDelta = 0;
    let pointerId = null;

    function getXY(e) {
      if (e.touches && e.touches.length) return { x: e.touches[0].clientX, y: e.touches[0].clientY };
      if (e.changedTouches && e.changedTouches.length) return { x: e.changedTouches[0].clientX, y: e.changedTouches[0].clientY };
      return { x: e.clientX, y: e.clientY };
    }

    function releaseCapture() {
      if (pointerId != null) {
        try { dragWrap.releasePointerCapture(pointerId); } catch (_) {}
        pointerId = null;
      }
    }

    function onDown(e) {
      if (e.type === 'pointerdown') {
        if (e.button > 1) return;
        if (!e.isPrimary) return;
      }
      if (e.target.closest?.('footer')) return;

      const { x, y } = getXY(e);
      isDragging = true;
      started = false;
      startX = lastClientX = x;
      startY = lastClientY = y;
      lastDragDelta = 0;

      gsap.killTweensOf(cols);
      dragWrap.classList.add('is-dragging');

      pointerId = e.pointerId ?? null;
      if (pointerId != null) {
        try { dragWrap.setPointerCapture(pointerId); } catch (_) {}
      }
      // En touch, no preventDefault en start: permite iniciar scroll vertical; el move decide.
      if (e.type !== 'touchstart') e.preventDefault();
    }

    function onMove(e) {
      if (!isDragging) return;
      const { x, y } = getXY(e);
      lastClientX = x;
      lastClientY = y;

      const dx = x - startX;
      const dy = y - startY;

      if (!started) {
        if (Math.abs(dx) <= DRAG_START_PX && Math.abs(dy) <= DRAG_START_PX) return;
        started = Math.abs(dx) >= Math.abs(dy);
        if (!started) {
          isDragging = false;
          releaseCapture();
          dragWrap.classList.remove('is-dragging');
          return;
        }
      }

      const maxR = active * colWidth();
      const maxL = (totalCols - 1 - active) * colWidth();
      lastDragDelta = Math.max(-maxL, Math.min(maxR, dx));
      cols.forEach((col, i) => gsap.set(col, { x: getNaturalX(i) + lastDragDelta }));
      e.preventDefault(); // bloquea scroll del documento / iframe durante arrastre horizontal
    }

    function finish(e) {
      releaseCapture();
      dragWrap.classList.remove('is-dragging');
      if (!isDragging) return;
      isDragging = false;

      const dx = lastClientX - startX;
      const dy = lastClientY - startY;

      if (!started && Math.abs(dx) < 15 && Math.abs(dy) < 15) {
        if (isDesktop()) {
          const { left, width } = dragWrap.getBoundingClientRect();
          const relX = startX - left;
          const peekPrev = active > 0 ? getPeek(cols[active - 1]) : 0;
          const peekNext = active < totalCols - 1 ? getPeek(cols[active + 1]) : 0;
          if (relX < peekPrev && active > 0)                     return setActive(active - 1);
          if (relX > width - peekNext && active < totalCols - 1) return setActive(active + 1);
        }
        return;
      }

      if (lastDragDelta > SWIPE_PX)  return setActive(active - 1);
      if (lastDragDelta < -SWIPE_PX) return setActive(active + 1);
      setActive(active);
    }

    function cancel() {
      releaseCapture();
      dragWrap.classList.remove('is-dragging');
      if (!isDragging) return;
      isDragging = false;
      setActive(active);
    }

    const useTouch = 'ontouchstart' in window;
    if (useTouch) {
      dragWrap.addEventListener('touchstart', onDown, { passive: false });
      dragWrap.addEventListener('touchmove', onMove, { passive: false });
      dragWrap.addEventListener('touchend', finish, { passive: false });
      dragWrap.addEventListener('touchcancel', cancel, { passive: true });
    } else {
      dragWrap.addEventListener('pointerdown', onDown, { passive: false });
      dragWrap.addEventListener('pointermove', onMove, { passive: false });
      dragWrap.addEventListener('pointerup', finish, { passive: true });
      dragWrap.addEventListener('pointercancel', cancel, { passive: true });
    }
  }

  // Navegación con trackpad horizontal (rueda/gesto de dos dedos en Mac).
  // Captura eventos wheel horizontales y navega cuando el delta acumulado supera el umbral.
  function initWheel() {
    const WHEEL_THRESHOLD = 60;
    const COOLDOWN_MS     = 600;
    let accDelta   = 0;
    let cooldown   = false;
    let resetT     = null;

    dragWrap.addEventListener('wheel', (e) => {
      if (Math.abs(e.deltaX) <= Math.abs(e.deltaY)) return;
      e.preventDefault();

      if (cooldown) return;

      accDelta += e.deltaX;

      clearTimeout(resetT);
      resetT = setTimeout(() => { accDelta = 0; }, 200);

      if (accDelta > WHEEL_THRESHOLD) {
        cooldown = true;
        accDelta = 0;
        setActive(active + 1);
        setTimeout(() => { cooldown = false; }, COOLDOWN_MS);
      } else if (accDelta < -WHEEL_THRESHOLD) {
        cooldown = true;
        accDelta = 0;
        setActive(active - 1);
        setTimeout(() => { cooldown = false; }, COOLDOWN_MS);
      }
    }, { passive: false });
  }

  active = 0;

  const HERO_DUR    = 0.8;
  const REVEAL_DUR  = 0.5;
  const REVEAL_EASE = 'power2.out';
  const SLIDE_OFFSET = 30;

  cols.forEach((col, i) => gsap.set(col, {
    x:               getNaturalX(i),
    scale:           getNaturalScale(i),
    transformOrigin: getNaturalOrigin(i),
    opacity:         i === 0 ? 1 : 0,
    zIndex:          i === 0 ? 1000 : 100,
    pointerEvents:   i === 0 ? 'auto' : 'none'
  }));

  gsap.set(nextBtn, { opacity: 0 });
  gsap.set([...prevTexts, ...nextTexts], { opacity: 0, y: 120 });

  const animBox = document.querySelector('.hg-home-box-animated');
  if (animBox) {
    const r  = animBox.getBoundingClientRect();
    const ix = Math.max(0, (r.width  - 150) / 2 / r.width  * 100).toFixed(2);
    const iy = Math.max(0, (r.height - 150) / 2 / r.height * 100).toFixed(2);
    gsap.set(animBox, { clipPath: `inset(${iy}% ${ix}%)` });
    gsap.to(animBox,  { clipPath: 'inset(0% 0%)', duration: HERO_DUR, ease: 'power1.inOut' });
  }

  gsap.delayedCall(HERO_DUR, () => {
    revealDone = true;
    if (cols[1]) {
      gsap.fromTo(cols[1],
        { opacity: 0, x: getNaturalX(1) + SLIDE_OFFSET },
        { opacity: 1, x: getNaturalX(1), duration: REVEAL_DUR, ease: REVEAL_EASE }
      );
    }
    if (!btnsHidden) gsap.to(nextBtn, { opacity: 1, duration: REVEAL_DUR, ease: REVEAL_EASE });
    if (nextTexts[1]) {
      gsap.fromTo(nextTexts[1],
        { opacity: 0, y: 120 },
        { opacity: 1, y: 0, duration: REVEAL_DUR, ease: REVEAL_EASE }
      );
      nextVis = 1;
    }
  });

  setActive(0);
  initDrag();
  initWheel();

  // Oculta botones y secciones inactivas cuando el footer de la columna activa entra en pantalla
  (function() {
    const footers = document.querySelectorAll('#hg-home-main footer');
    if (!footers.length) return;
    const visibleFooters = new Set();

    // Oculta o muestra botones y secciones inactivas según si el footer de la columna
    // activa está visible. Evita animar si el estado ya era el mismo.
    function syncBtns() {
      const activeIndex = parseInt(row.dataset.active || '0', 10);
      const shouldHide = visibleFooters.has(footers[activeIndex]);
      if (shouldHide === btnsHidden) return;
      btnsHidden = shouldHide;

      const inactiveCols = cols.filter((_, i) => i !== activeIndex);
      gsap.to([prevBtn, nextBtn, ...inactiveCols], {
        opacity:       shouldHide ? 0 : 1,
        pointerEvents: shouldHide ? 'none' : 'auto',
        duration:      0.15,
        ease:          'power2.out'
      });
    }

    updateFooterInView = syncBtns;

    const observer = new IntersectionObserver(function(entries) {
      entries.forEach(function(entry) {
        if (entry.isIntersecting) visibleFooters.add(entry.target);
        else visibleFooters.delete(entry.target);
      });
      syncBtns();
    }, { threshold: 0.2 });
    footers.forEach(function(f) { observer.observe(f); });
  })();
})();
</script>
