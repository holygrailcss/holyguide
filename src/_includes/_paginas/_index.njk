---
layout: base.njk
---

{# ── HERO ──────────────────────────────────────────────────────────────── #}
<section class="home-hero">
  <div class="container">
    <div class="row">
      <div class="col-xs-12 col-md-6">

        <div class="home-hero__eyebrow">Design System · Holyguide</div>

        <h1 class="home-hero__title">Holy<br>guide</h1>

        <p class="home-hero__desc">
          Biblioteca de componentes, tokens de diseño y guías de uso para
          construir interfaces consistentes y escalables.
        </p>

        <div class="home-hero__actions">
          <a href="/foundations" class="btn btn-primary label-m">Empezar →</a>
          <a href="/components" class="btn btn-secondary label-m" style="border-color:#fff;color:#fff;background:transparent;">Componentes</a>
        </div>

        <div class="home-hero__npm" onclick="navigator.clipboard.writeText('npm install holygrail2').then(()=>{ this.querySelector('span').textContent='¡Copiado!'; setTimeout(()=>{ this.querySelector('span').textContent='npm install holygrail2'; },1800); })">
          <svg width="14" height="14" viewBox="0 0 16 16" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M4 4v-1a2 2 0 0 1 2-2h6a2 2 0 0 1 2 2v8a2 2 0 0 1-2 2h-1"/><rect x="2" y="6" width="8" height="8" rx="1.5"/></svg>
          <span>npm install holygrail2</span>
        </div>

        <div class="home-hero__meta mt-24">
          <div class="home-hero__version">
            <a href="https://www.npmjs.com/package/holygrail2" target="_blank" rel="nofollow">
              <img src="https://img.shields.io/npm/v/holygrail2" alt="npm version" style="vertical-align:middle;">
            </a>
          </div>
          <div class="home-hero__version">
            <a href="https://www.npmjs.com/package/holygrail2" target="_blank" rel="nofollow">
              <img src="https://img.shields.io/npm/dm/holygrail2.svg" alt="npm downloads" style="vertical-align:middle;">
            </a>
          </div>
        </div>

      </div>

      <div class="col-xs-12 col-md-6">
        <div class="zona-img mb-64">
          <div class="zona-img-1 box">
            <img width="100%" src="/assets/static/images/pdp1.jpg" alt="">
          </div>
          <div class="zona-img-2 box">
            <img width="100%" src="/assets/static/images/pdp3.jpg" alt="">
          </div>
          <div class="zona-img-3 box">
            <img width="100%" src="/assets/static/images/pdp2.jpg" alt="">
          </div>
          <div class="zona-img-4 box"><img width="60px" src="/assets/static/images/icon1.jpg" alt=""></div>
          <div class="zona-img-5 box"><img width="60px" src="/assets/static/images/icon2.jpg" alt=""></div>
          <div class="zona-img-6 box"><img width="60px" src="/assets/static/images/icon3.jpg" alt=""></div>
          <div class="zona-img-7 box"><img width="60px" src="/assets/static/images/icon4.jpg" alt=""></div>
        </div>
      </div>

    </div>
  </div>
</section>

{# ── SECCIONES ─────────────────────────────────────────────────────────── #}
<section class="home-sections">
  <div class="container">

    <div class="home-sections__title">Explorar</div>

    <div class="home-grid">

      <a href="/foundations" class="home-card">
        <div class="home-card__icon">
          <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="3" y="3" width="7" height="7"/><rect x="14" y="3" width="7" height="7"/><rect x="3" y="14" width="7" height="7"/><rect x="14" y="14" width="7" height="7"/></svg>
        </div>
        <div>
          <div class="home-card__label">01</div>
          <div class="home-card__name">Foundations</div>
        </div>
        <div class="home-card__desc">Tokens de color, tipografía, espaciado, grid y motion.</div>
        <div class="home-card__arrow">↗</div>
      </a>

      <a href="/components" class="home-card">
        <div class="home-card__icon">
          <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M12 2l9 4.5v9L12 20l-9-4.5v-9z"/><polyline points="12 2 12 20"/><line x1="3" y1="6.5" x2="21" y2="6.5"/></svg>
        </div>
        <div>
          <div class="home-card__label">02</div>
          <div class="home-card__name">Componentes</div>
        </div>
        <div class="home-card__desc">Botones, inputs, modales, acordeones, tabs y más.</div>
        <div class="home-card__arrow">↗</div>
      </a>

      <a href="/develop" class="home-card">
        <div class="home-card__icon">
          <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polyline points="16 18 22 12 16 6"/><polyline points="8 6 2 12 8 18"/></svg>
        </div>
        <div>
          <div class="home-card__label">03</div>
          <div class="home-card__name">Develop</div>
        </div>
        <div class="home-card__desc">Guías de instalación, arquitectura y buenas prácticas.</div>
        <div class="home-card__arrow">↗</div>
      </a>

      <a href="/templates-2026" class="home-card">
        <div class="home-card__icon">
          <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="3" y="3" width="18" height="18" rx="2"/><line x1="3" y1="9" x2="21" y2="9"/><line x1="9" y1="21" x2="9" y2="9"/></svg>
        </div>
        <div>
          <div class="home-card__label">04</div>
          <div class="home-card__name">Templates</div>
        </div>
        <div class="home-card__desc">Parrillas y estructuras de página listas para usar.</div>
        <div class="home-card__arrow">↗</div>
      </a>

    </div>
  </div>
</section>

{# ── MANIFIESTO ────────────────────────────────────────────────────────── #}
<section class="home-manifesto">
  <div class="container">
    <div class="row">
      <div class="col-xs-12 col-md-10">
        <h2 class="home-manifesto__text">
          Un sistema de diseño es el lenguaje común entre
          diseñadores y desarrolladores. Holyguide lo hace
          coherente, predecible y escalable.
        </h2>
        <p class="home-manifesto__sub">
          Construido para equipos que necesitan moverse rápido sin perder consistencia.
          Cada componente está documentado, cada token explicado.
        </p>
      </div>
    </div>
  </div>
</section>

{# ── ÚLTIMOS TEMPLATES ─────────────────────────────────────────────────── #}
<section class="home-templates">
  <div class="container">
    <div class="home-templates__header">
      <div class="home-templates__title">Últimos templates</div>
      <a href="/templates-2026" class="home-templates__link">Ver todos →</a>
    </div>
    <div class="grid-5">
      {% for component in collections["templates-2026"] | reverse %}
        {% if loop.index <= 5 %}
          {% include 'token-loop-list.njk' %}
        {% endif %}
      {% endfor %}
    </div>
  </div>
</section>

{# ── CTA ───────────────────────────────────────────────────────────────── #}
<section class="home-cta">
  <div class="container">
    <div class="home-cta__inner">
      <div>
        <div class="home-cta__text">¿Necesitas ayuda?</div>
        <div class="home-cta__sub">Contacta con el equipo de design systems.</div>
      </div>
      <a href="mailto:design@example.com" class="btn btn-secondary label-m" style="border-color:#333;color:#fff;background:transparent;">
        Contactar →
      </a>
    </div>
  </div>
</section>
