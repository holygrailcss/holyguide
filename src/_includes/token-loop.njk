      <article class="">
          <a class="w-100" href="{{ component.url }}">
            <div class="rat-16-9 w-100">
              <div class="rat-content">
   {# {% include '_components/'+component.data.titulo +'.njk' %}  #}
  <img class="video-cover" width="100%" height="100%" src="{{ component.data.image }}" alt="{{ component.titulo }}">
              </div>
            </div>
                </a>
          <div class="article-text mt-24">
              <div class="mb-16">
                <h4 class="ttu bold article-title-with-badge">
                  <a href="{{ component.data.titulo }}">{{ component.data.titulo }}</a>
                  {% if component.data.badge %}<span class="nav-badge nav-badge--{{ component.data.badge }}">{{ component.data.badge }}</span>{% endif %}
                </h4>

                  <div class="article-content">
             <p >{{ component.data.descripcion }}</p></div>
              </div>
              {#     
              {% set sortedTags = component.data.tags | sort %}

          
              {% for tag in sortedTags %}
              <div class=" tag-info text-12-r">
                {{ tag }}
              </div>
              {% endfor %} #}
          </div>
      </article>
