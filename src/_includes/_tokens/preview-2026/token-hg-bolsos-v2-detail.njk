<section class="bolsosd_wrap" data-items='[
  {% for item in items %}{"idx":"{{item.idx}}","label":"{{item.label}}","by":"{{item.by}}","video":"{{item.video}}","poster":"{{item.poster}}"}{% if not loop.last %},{% endif %}{% endfor %}
]'>

  {# Stage pinned: video de fondo + caption flotante + shelf #}
  <div class="bolsosd_stage">

    {# Dos <img> apilados para hacer crossfade del fondo entre el item actual y el siguiente.
       Al clicar una miniatura, su imagen pasa al fondo (a la imagen "back", que se hace front
       con un fade) — la del shelf siempre coincide con la grande. #}
    <img id="bolsosd_image_a" class="bolsosd_video is-front" src="{{ items[0].thumb }}" alt="" aria-hidden="true" />
    <img id="bolsosd_image_b" class="bolsosd_video" src="" alt="" aria-hidden="true" />

    {# Etiqueta marca arriba a la izquierda #}
    <div class="bolsosd_brand title-l ttu">Bolsos</div>

    {# Caption flotante a la izquierda — al cambiar, el texto hace fade-out con
       opacidad y luego aparece el nuevo con fade-in. #}
    <div class="bolsosd_caption" aria-live="polite">
      <div class="bolsosd_caption-inner">
        <div class="bolsosd_caption-idx title-l" data-bind="idx">[ {{ items[0].idx }} ]</div>
        <div class="bolsosd_caption-label title-l ttu" data-bind="label">{{ items[0].label }}</div>
        <div class="bolsosd_caption-by title-l ttu" data-bind="by">Featured by: {{ items[0].by }}</div>
        <a href="#" class="bolsosd_buy title-l ttu" data-bind="buy">BUY</a>
      </div>
    </div>

    {# Shelf de miniaturas en la parte inferior #}
    <div class="bolsosd_shelf-wrap">
      <ul class="bolsosd_shelf list-clear m-0 p-0" role="list">
        {% for item in items %}
        <li class="bolsosd_thumb-li">
          <button type="button"
                  class="bolsosd_thumb {% if loop.index0 == 0 %}is-active{% endif %}"
                  data-idx="{{ item.idx }}"
                  data-image="{{ item.thumb }}"
                  data-label="{{ item.label }}"
                  data-by="{{ item.by }}"
                  aria-label="Ver {{ item.label }} — featured by {{ item.by }}">
            <img class="bolsosd_thumb-img" src="{{ item.thumb }}" alt="" loading="lazy" />
            <span class="bolsosd_thumb-idx title-l">[ {{ item.idx }} ]</span>
          </button>
        </li>
        {% endfor %}
      </ul>
    </div>

  </div>

  {# Bloques transparentes para dar altura al scroll (sin tocar el vídeo, sólo cambian el texto) #}
  <div class="bolsosd_scrollspace" aria-hidden="true">
    {% for item in items %}
    <div class="bolsosd_scrollstep"
         data-idx="{{ item.idx }}"
         data-label="{{ item.label }}"
         data-by="{{ item.by }}"></div>
    {% endfor %}
  </div>
</section>

<script src="https://cdn.jsdelivr.net/npm/gsap@3.12.5/dist/gsap.min.js"></script>
<script src="https://cdn.jsdelivr.net/npm/gsap@3.12.5/dist/ScrollTrigger.min.js"></script>
<script>
(function () {
  const root = document.querySelector('.bolsosd_wrap');
  if (!root) return;

  const stage      = root.querySelector('.bolsosd_stage');
  const imageA     = root.querySelector('#bolsosd_image_a');
  const imageB     = root.querySelector('#bolsosd_image_b');
  const thumbs     = Array.from(root.querySelectorAll('.bolsosd_thumb'));
  const captionIdx = root.querySelector('[data-bind="idx"]');
  const captionLbl = root.querySelector('[data-bind="label"]');
  const captionBy  = root.querySelector('[data-bind="by"]');
  const steps      = Array.from(root.querySelectorAll('.bolsosd_scrollstep'));
  const reduceMotion = window.matchMedia('(prefers-reduced-motion: reduce)');

  // Estado: qué <img> está al frente (la otra recibe la nueva imagen y crossfade encima)
  let front = imageA;
  let back  = imageB;
  let currentImageSrc = imageA.getAttribute('src') || '';

  // ---------- Estado inicial desde ?item=NN ----------
  function getItemFromQuery() {
    const params = new URLSearchParams(window.location.search);
    const idx = params.get('item');
    if (!idx) return null;
    return thumbs.find(t => t.dataset.idx === idx) || null;
  }

  // ---------- Cambio de imagen de fondo con crossfade GSAP ----------
  // Cargamos la nueva imagen en el <img> "back" (oculto). Esperamos a que
  // termine de descargar para no ver un parpadeo en blanco. Antes del fade
  // FORZAMOS que el back esté en z-index superior: si no, según cuál de los
  // dos <img> sea (DOM-antes o DOM-después), el otro se le pondría delante
  // y el fade ocurriría tapado → la imagen aparecía "de golpe" al terminar.
  function swapImage(newSrc) {
    if (!newSrc || newSrc === currentImageSrc) return;
    currentImageSrc = newSrc;

    const showBack = () => {
      // Z-index: el back que vamos a fade-in tiene que estar EN FRENTE.
      back.style.zIndex  = 2;
      front.style.zIndex = 1;

      if (reduceMotion.matches) {
        front.classList.remove('is-front');
        back.classList.add('is-front');
        front.style.opacity = '';
        back.style.opacity  = '';
        [front, back] = [back, front];
        return;
      }

      gsap.to(back, {
        opacity: 1, duration: 0.55, ease: 'power2.out', overwrite: 'auto',
        onComplete: () => {
          back.classList.add('is-front');
          front.classList.remove('is-front');
          front.style.opacity = 0;
          // swap referencias
          [front, back] = [back, front];
          back.style.opacity = 0;
        }
      });
    };

    // Si la imagen ya está cacheada el `complete` es true tras asignar src;
    // si no, esperamos al `load` para evitar un fade hacia un <img> en blanco.
    back.style.opacity = 0;
    back.onload = null;
    back.onerror = null;
    back.src = newSrc;
    if (back.complete && back.naturalWidth > 0) {
      showBack();
    } else {
      back.onload  = showBack;
      back.onerror = () => { /* la imagen no se pudo cargar — dejamos el front actual */ };
    }
  }

  // ---------- Shelf: el estado activo lo lleva CSS (escala + hover) ----------
  // GSAP no toca el `transform` de las miniaturas: si lo tocara, dejaría inline-styles
  // que ganarían a la regla CSS :hover. Aquí sólo añadimos/quitamos la clase .is-active.
  function setActiveThumb(target) {
    if (!target) return;
    const previous = thumbs.find(t => t.classList.contains('is-active'));
    if (previous === target) return;
    if (previous) previous.classList.remove('is-active');
    target.classList.add('is-active');
  }
  // Nota: el shelf está alineado a la izquierda y crece hacia la derecha. El primer
  // thumb nunca cambia de posición, así que la alineación del caption la hace CSS.

  // ---------- Cambio de texto del caption: fade-out → swap → fade-in ----------
  // Pasos:
  //   1) Todo el bloque desaparece a opacity 0 al mismo tiempo (sin stagger).
  //   2) Cuando ya no se ve nada, intercambiamos el textContent de las tres líneas.
  //   3) Aparece el nuevo texto con un fade-in al unísono.
  // Una única timeline asegura que el swap ocurre EXACTAMENTE cuando opacity = 0.
  function setCaptionText({ idx, label, by }) {
    if (captionIdx.textContent === '[ ' + idx + ' ]' &&
        captionLbl.textContent === label &&
        captionBy.textContent  === 'Featured by: ' + by) {
      return; // ya está
    }
    if (reduceMotion.matches) {
      captionIdx.textContent = '[ ' + idx + ' ]';
      captionLbl.textContent = label;
      captionBy.textContent  = 'Featured by: ' + by;
      return;
    }
    const parts = [captionIdx, captionLbl, captionBy];
    gsap.timeline({ overwrite: 'auto' })
      // 1) fade-out — overwrite: 'auto' cancela cualquier animación previa en curso
      .to(parts, { opacity: 0, duration: 0.25, ease: 'power1.in' })
      // 2) swap del texto exactamente al llegar a 0
      .add(() => {
        captionIdx.textContent = '[ ' + idx + ' ]';
        captionLbl.textContent = label;
        captionBy.textContent  = 'Featured by: ' + by;
      })
      // 3) fade-in del nuevo texto
      .to(parts, { opacity: 1, duration: 0.35, ease: 'power2.out' });
  }

  // ---------- Activación completa por índice: vídeo + shelf + caption ----------
  // Es la función central que llaman click, scroll y focus (Tab).
  // Es idempotente: si el item ya está activo, no vuelve a animar.
  function activateByIndex(i, opts) {
    const t = thumbs[i];
    if (!t) return;
    const wasActive = t.classList.contains('is-active');
    setActiveThumb(t);
    swapImage(t.dataset.image);
    setCaptionText({ idx: t.dataset.idx, label: t.dataset.label, by: t.dataset.by });
    // Llevamos la miniatura activa al centro del shelf (sólo si no es por scroll de página).
    if (!wasActive && !(opts && opts.skipScrollIntoView)) {
      t.scrollIntoView({ behavior: 'smooth', block: 'nearest', inline: 'center' });
    }
  }

  // ---------- Click en una miniatura ----------
  thumbs.forEach((t, i) => {
    t.addEventListener('click', () => activateByIndex(i));
  });

  // ---------- Tab / foco de teclado: al recibir foco, activa el item ----------
  // Con `<button>`s, Tab navega de uno a otro de forma nativa. Al recibir foco,
  // dejamos que el item se active igual que si hubieras clicado.
  thumbs.forEach((t, i) => {
    t.addEventListener('focus', () => activateByIndex(i));
  });

  // También navegación por flechas izquierda/derecha cuando un thumb tiene el foco.
  root.querySelector('.bolsosd_shelf').addEventListener('keydown', (e) => {
    if (e.key !== 'ArrowLeft' && e.key !== 'ArrowRight') return;
    const current = thumbs.findIndex(t => t === document.activeElement);
    if (current < 0) return;
    const next = e.key === 'ArrowRight'
      ? Math.min(thumbs.length - 1, current + 1)
      : Math.max(0, current - 1);
    e.preventDefault();
    thumbs[next].focus(); // dispara focus → activateByIndex
  });

  // ---------- Estado inicial ----------
  const startThumb = getItemFromQuery() || thumbs[0];
  const startIdx = thumbs.indexOf(startThumb);
  if (startIdx > 0) {
    activateByIndex(startIdx, { skipScrollIntoView: true });
  } else {
    // El primero ya viene pintado en HTML — sólo aseguro el active
    setActiveThumb(thumbs[0]);
  }

  // ---------- Scroll → AVANZA entre imágenes (vídeo + shelf + caption) ----------
  if (window.gsap && window.ScrollTrigger) {
    gsap.registerPlugin(ScrollTrigger);

    // El stage queda fijo (pin) durante el scroll de todos los scrollsteps.
    // `invalidateOnRefresh: true` → recomputa medidas al hacer refresh
    // (necesario para que el pin se adapte al cambiar la viewport).
    ScrollTrigger.create({
      trigger: '.bolsosd_wrap',
      start: 'top top',
      end:   'bottom bottom',
      pin:   '.bolsosd_stage',
      pinSpacing: false,
      invalidateOnRefresh: true
    });

    // Cada scrollstep activa su item al entrar en el centro de la viewport.
    // Se pasa skipScrollIntoView para no encadenar un scroll del shelf con el de la página.
    steps.forEach((step, i) => {
      ScrollTrigger.create({
        trigger: step,
        start: 'top center',
        end:   'bottom center',
        invalidateOnRefresh: true,
        onEnter:     () => activateByIndex(i, { skipScrollIntoView: true }),
        onEnterBack: () => activateByIndex(i, { skipScrollIntoView: true })
      });
    });

    // ScrollTrigger refresca solo en `resize` del window, pero en iframes que
    // cambian de tamaño (resize-bar del viewer) los listeners pueden no
    // dispararse. Lo forzamos también con ResizeObserver sobre el wrap y con
    // un fallback en `resize` del window con debounce.
    let resizeRaf = 0;
    const scheduleRefresh = () => {
      if (resizeRaf) cancelAnimationFrame(resizeRaf);
      resizeRaf = requestAnimationFrame(() => {
        ScrollTrigger.refresh();
        resizeRaf = 0;
      });
    };
    window.addEventListener('resize', scheduleRefresh);
    if ('ResizeObserver' in window) {
      new ResizeObserver(scheduleRefresh).observe(root);
    }
  }

  // ---------- prefers-reduced-motion ----------
  // El swap de imagen ya consulta reduceMotion.matches en cada llamada.
  // Aquí no hay que hacer nada extra (las imágenes son estáticas).

})();
</script>
{% endblock %}
