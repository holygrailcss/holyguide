{% extends "base-clean.njk" %}
{% block content %}
{# Token hg-bolsos-v2-detail: hero con bg-video + caption flotante + shelf. GSAP para click & scroll. #}
<link rel="stylesheet" href="https://hg5.netlify.app/output.css" />
<link rel="stylesheet" href="/assets/css/hg-bolsos-v2-detail.css" />

{% set items = [
  { idx: '01', label: 'BAG, SATCHEL BAG',     by: 'LOU DOILLON', poster: '/assets/static/templates/timeline/colonia.jpg',          video: '/assets/video/bag-01.mp4', thumb: '/assets/static/templates/timeline/colonia.jpg' },
  { idx: '02', label: 'BAG, SHOULDER BAG',    by: 'LOU DOILLON', poster: '/assets/static/templates/timeline/contraluz-hombre.jpg', video: '/assets/video/bag-02.mp4', thumb: '/assets/static/templates/timeline/contraluz-hombre.jpg' },
  { idx: '03', label: 'BAG, BUCKET BAG',      by: 'LOU DOILLON', poster: '/assets/static/templates/timeline/pasarela.jpg',         video: '/assets/video/bag-03.mp4', thumb: '/assets/static/templates/timeline/pasarela.jpg' },
  { idx: '04', label: 'BAG, TOTE BAG',        by: 'LOU DOILLON', poster: '/assets/static/templates/timeline/fachada-piedra.jpg',   video: '/assets/video/bag-04.mp4', thumb: '/assets/static/templates/timeline/fachada-piedra.jpg' },
  { idx: '05', label: 'BAG, CROSSBODY BAG',   by: 'LOU DOILLON', poster: '/assets/static/templates/timeline/web.jpg',              video: '/assets/video/bag-05.mp4', thumb: '/assets/static/templates/timeline/web.jpg' },
  { idx: '06', label: 'BAG, HOBO BAG',        by: 'LOU DOILLON', poster: '/assets/static/templates/timeline/espuela.jpg',          video: '/assets/video/bag-06.mp4', thumb: '/assets/static/templates/timeline/espuela.jpg' },
  { idx: '07', label: 'BAG, MINI BAG',        by: 'LOU DOILLON', poster: '/assets/static/templates/timeline/bw-espalda.jpg',       video: '/assets/video/bag-07.mp4', thumb: '/assets/static/templates/timeline/bw-espalda.jpg' },
  { idx: '08', label: 'BAG, CLUTCH',          by: 'LOU DOILLON', poster: '/assets/static/templates/timeline/modelo-andando.jpg',   video: '/assets/video/bag-08.mp4', thumb: '/assets/static/templates/timeline/modelo-andando.jpg' },
  { idx: '09', label: 'BAG, SHOPPER BAG',     by: 'LOU DOILLON', poster: '/assets/static/templates/timeline/niña.jpg',             video: '/assets/video/bag-09.mp4', thumb: '/assets/static/templates/timeline/niña.jpg' },
  { idx: '10', label: 'BAG, BAGUETTE BAG',    by: 'LOU DOILLON', poster: '/assets/static/templates/timeline/pancarta.jpg',         video: '/assets/video/bag-10.mp4', thumb: '/assets/static/templates/timeline/pancarta.jpg' },
  { idx: '11', label: 'BAG, BOX BAG',         by: 'LOU DOILLON', poster: '/assets/static/templates/timeline/gafas.jpg',            video: '/assets/video/bag-11.mp4', thumb: '/assets/static/templates/timeline/gafas.jpg' },
  { idx: '12', label: 'BAG, SATCHEL BAG',     by: 'LOU DOILLON', poster: '/assets/static/templates/timeline/contraluz-mujer.jpg',  video: '/assets/video/bag-12.mp4', thumb: '/assets/static/templates/timeline/contraluz-mujer.jpg' },
  { idx: '13', label: 'BAG, BACKPACK',        by: 'LOU DOILLON', poster: '/assets/static/templates/timeline/1985-detalle-1.jpg',   video: '/assets/video/bag-13.mp4', thumb: '/assets/static/templates/timeline/1985-detalle-1.jpg' },
  { idx: '14', label: 'BAG, WALLET',          by: 'LOU DOILLON', poster: '/assets/static/templates/timeline/1985-detalle-2.jpg',   video: '/assets/video/bag-14.mp4', thumb: '/assets/static/templates/timeline/1985-detalle-2.jpg' },
  { idx: '15', label: 'BAG, BUCKET BAG',      by: 'LOU DOILLON', poster: '/assets/static/templates/timeline/1991-detalle-1.jpg',   video: '/assets/video/bag-15.mp4', thumb: '/assets/static/templates/timeline/1991-detalle-1.jpg' },
  { idx: '16', label: 'BAG, TOTE BAG',        by: 'LOU DOILLON', poster: '/assets/static/templates/timeline/1991-detalle-2.jpg',   video: '/assets/video/bag-16.mp4', thumb: '/assets/static/templates/timeline/1991-detalle-2.jpg' },
  { idx: '17', label: 'BAG, SHOULDER BAG',    by: 'LOU DOILLON', poster: '/assets/static/templates/timeline/1995-detalle-1.jpg',   video: '/assets/video/bag-17.mp4', thumb: '/assets/static/templates/timeline/1995-detalle-1.jpg' },
  { idx: '18', label: 'BAG, MINI BAG',        by: 'LOU DOILLON', poster: '/assets/static/templates/timeline/1995-detalle-2.jpg',   video: '/assets/video/bag-18.mp4', thumb: '/assets/static/templates/timeline/1995-detalle-2.jpg' },
  { idx: '19', label: 'BAG, CROSSBODY BAG',   by: 'LOU DOILLON', poster: '/assets/static/templates/timeline/1997-detalle-1.jpg',   video: '/assets/video/bag-19.mp4', thumb: '/assets/static/templates/timeline/1997-detalle-1.jpg' },
  { idx: '20', label: 'BAG, CLUTCH',          by: 'LOU DOILLON', poster: '/assets/static/templates/timeline/1997-detalle-2.jpg',   video: '/assets/video/bag-20.mp4', thumb: '/assets/static/templates/timeline/1997-detalle-2.jpg' }
