{% extends "base-clean.njk" %}
{% block content %}
{# Token hg-bolsos-v2-detail: hero con bg-video + caption flotante + shelf. GSAP para click & scroll. #}
<link rel="stylesheet" href="https://hg5.netlify.app/output.css" />
<link rel="stylesheet" href="/assets/css/hg-bolsos-v2-detail.css" />

{# items 1:1 con el grid principal (token-hg-bolsos-v2.njk).
   - thumb = imagen (poster) que se usa en el shelf de miniaturas.
   - video = URL del .mp4 que se reproduce en el background del hero.
   El número (idx) debe coincidir con el del grid: ?item=09 muestra el vídeo del item 09. #}
{% set items = [
  { idx: '01', label: 'BAG, SATCHEL BAG',     by: 'LOU DOILLON', thumb: '/assets/static/templates/timeline/colonia.jpg',          video: 'https://videos.pexels.com/video-files/3195650/3195650-hd_1920_1080_25fps.mp4' },
  { idx: '02', label: 'BAG, SHOULDER BAG',    by: 'LOU DOILLON', thumb: '/assets/static/templates/timeline/contraluz-hombre.jpg', video: 'https://videos.pexels.com/video-files/3129957/3129957-hd_1920_1080_25fps.mp4' },
  { idx: '03', label: 'BAG, BUCKET BAG',      by: 'LOU DOILLON', thumb: '/assets/static/templates/timeline/pasarela.jpg',         video: 'https://videos.pexels.com/video-files/3255275/3255275-hd_1920_1080_25fps.mp4' },
  { idx: '04', label: 'BAG, TOTE BAG',        by: 'LOU DOILLON', thumb: '/assets/static/templates/timeline/fachada-piedra.jpg',   video: 'https://videos.pexels.com/video-files/6981411/6981411-hd_1920_1080_25fps.mp4' },
  { idx: '05', label: 'BAG, CROSSBODY BAG',   by: 'LOU DOILLON', thumb: '/assets/static/templates/timeline/web.jpg',              video: 'https://videos.pexels.com/video-files/4770380/4770380-hd_1920_1080_30fps.mp4' },
  { idx: '06', label: 'BAG, HOBO BAG',        by: 'LOU DOILLON', thumb: '/assets/static/templates/timeline/espuela.jpg',          video: 'https://videos.pexels.com/video-files/855289/855289-hd_1920_1080_25fps.mp4' },
  { idx: '07', label: 'BAG, MINI BAG',        by: 'LOU DOILLON', thumb: '/assets/static/templates/timeline/bw-espalda.jpg',       video: 'https://videos.pexels.com/video-files/1536322/1536322-hd_1920_1080_30fps.mp4' },
  { idx: '08', label: 'BAG, CLUTCH',          by: 'LOU DOILLON', thumb: '/assets/static/templates/timeline/modelo-andando.jpg',   video: 'https://videos.pexels.com/video-files/6981411/6981411-hd_1920_1080_25fps.mp4' },
  { idx: '09', label: 'BAG, SHOPPER BAG',     by: 'LOU DOILLON', thumb: '/assets/static/templates/timeline/niña.jpg',             video: 'https://videos.pexels.com/video-files/3195650/3195650-hd_1920_1080_25fps.mp4' },
  { idx: '10', label: 'BAG, BAGUETTE BAG',    by: 'LOU DOILLON', thumb: '/assets/static/templates/timeline/pancarta.jpg',         video: 'https://videos.pexels.com/video-files/853889/853889-hd_1920_1080_25fps.mp4' },
  { idx: '11', label: 'BAG, BOX BAG',         by: 'LOU DOILLON', thumb: '/assets/static/templates/timeline/gafas.jpg',            video: 'https://videos.pexels.com/video-files/3255275/3255275-hd_1920_1080_25fps.mp4' },
  { idx: '12', label: 'BAG, SATCHEL BAG',     by: 'LOU DOILLON', thumb: '/assets/static/templates/timeline/contraluz-mujer.jpg',  video: 'https://videos.pexels.com/video-files/853889/853889-hd_1920_1080_25fps.mp4' },
  { idx: '13', label: 'BAG, BACKPACK',        by: 'LOU DOILLON', thumb: '/assets/static/templates/timeline/1985-detalle-1.jpg',   video: 'https://videos.pexels.com/video-files/3129957/3129957-hd_1920_1080_25fps.mp4' },
  { idx: '14', label: 'BAG, WALLET',          by: 'LOU DOILLON', thumb: '/assets/static/templates/timeline/1985-detalle-2.jpg',   video: 'https://videos.pexels.com/video-files/1536322/1536322-hd_1920_1080_30fps.mp4' },
  { idx: '15', label: 'BAG, BUCKET BAG',      by: 'LOU DOILLON', thumb: '/assets/static/templates/timeline/1991-detalle-1.jpg',   video: 'https://videos.pexels.com/video-files/855289/855289-hd_1920_1080_25fps.mp4' }
] %}

<section class="bolsos-v2-detail_wrap">

  {# Stage pinned: video de fondo + caption flotante + shelf #}
  <div class="bolsos-v2-detail_stage">

    {# Dos <video> apilados (a/b) para hacer crossfade del fondo al cambiar de item.
       Cuando se activa otro item, su .mp4 se asigna al vídeo "back", esperamos a `canplay`
       y entonces fade-in del back / fade-out del front. La miniatura (thumb) se usa como
       `poster` para evitar parpadeo negro mientras carga.
       Atributos clave: muted (autoplay requirement), loop, playsinline (iOS no fullscreen). #}
    <video
      id="bolsos-v2-detail_video_a"
      class="bolsos-v2-detail_video is-front"
      muted loop playsinline preload="metadata" autoplay
      poster="{{ items[0].thumb }}"
      src="{{ items[0].video }}"
      aria-hidden="true"></video>
    <video
      id="bolsos-v2-detail_video_b"
      class="bolsos-v2-detail_video"
      muted loop playsinline preload="metadata"
      aria-hidden="true"></video>

    {# Etiqueta marca arriba a la izquierda #}
    <div class="bolsos-v2-detail_brand title-l ttu">Bolsos</div>

    {# Caption flotante a la izquierda — al cambiar, el texto hace fade-out con
       opacidad y luego aparece el nuevo con fade-in. #}
    <div class="bolsos-v2-detail_caption" aria-live="polite">
      <div class="bolsos-v2-detail_caption-inner">
        <div class="bolsos-v2-detail_caption-idx title-l" data-bind="idx">[ {{ items[0].idx }} ]</div>
        <div class="bolsos-v2-detail_caption-label title-l ttu" data-bind="label">{{ items[0].label }}</div>
        <div class="bolsos-v2-detail_caption-by title-l ttu" data-bind="by">Featured by: {{ items[0].by }}</div>
        <button type="button" class="bolsos-v2-detail_buy title-l ttu" data-bind="buy">BUY</button>
      </div>
    </div>

    {# Shelf de miniaturas en la parte inferior #}
    <div class="bolsos-v2-detail_shelf-wrap">
      <ul class="bolsos-v2-detail_shelf list-clear m-0 p-0" role="list">
        {% for item in items %}
        <li class="bolsos-v2-detail_thumb-li">
          <button type="button"
                  class="bolsos-v2-detail_thumb {% if loop.index0 == 0 %}is-active{% endif %}"
                  data-idx="{{ item.idx }}"
                  data-image="{{ item.thumb }}"
                  data-video="{{ item.video }}"
                  data-label="{{ item.label }}"
                  data-by="{{ item.by }}"
                  aria-label="Ver {{ item.label }} — featured by {{ item.by }}">
            <img class="bolsos-v2-detail_thumb-img" src="{{ item.thumb }}" alt="" loading="lazy" />
            <span class="bolsos-v2-detail_thumb-idx title-l">[ {{ item.idx }} ]</span>
          </button>
        </li>
        {% endfor %}
      </ul>
    </div>

  </div>

  {# Bloques transparentes para dar altura al scroll (sin tocar el vídeo, sólo cambian el texto) #}
  <div class="bolsos-v2-detail_scrollspace" aria-hidden="true">
    {% for item in items %}
    <div class="bolsos-v2-detail_scrollstep"
         data-idx="{{ item.idx }}"
         data-label="{{ item.label }}"
         data-by="{{ item.by }}"></div>
    {% endfor %}
  </div>
</section>

<script src="https://cdn.jsdelivr.net/npm/gsap@3.12.5/dist/gsap.min.js"></script>
<script src="https://cdn.jsdelivr.net/npm/gsap@3.12.5/dist/ScrollTrigger.min.js"></script>
<script>
(function () {
  const root = document.querySelector('.bolsos-v2-detail_wrap');
  if (!root) return;

  const stage      = root.querySelector('.bolsos-v2-detail_stage');
  const videoA     = root.querySelector('#bolsos-v2-detail_video_a');
  const videoB     = root.querySelector('#bolsos-v2-detail_video_b');
  const thumbs     = Array.from(root.querySelectorAll('.bolsos-v2-detail_thumb'));
  const captionIdx = root.querySelector('[data-bind="idx"]');
  const captionLbl = root.querySelector('[data-bind="label"]');
  const captionBy  = root.querySelector('[data-bind="by"]');
  const steps      = Array.from(root.querySelectorAll('.bolsos-v2-detail_scrollstep'));
  const reduceMotion = window.matchMedia('(prefers-reduced-motion: reduce)');

  // Estado: qué <video> está al frente (el otro recibe la nueva src y crossfade encima).
  let front = videoA;
  let back  = videoB;
  let currentVideoSrc = videoA.getAttribute('src') || '';

  // Arrancar el primer vídeo (autoplay puede estar bloqueado en algunos navegadores
  // hasta que haya interacción del usuario; si falla, no hacemos nada).
  if (!reduceMotion.matches) {
    front.play().catch(() => {});
  } else {
    front.pause();
  }

  // ---------- Estado inicial desde ?item=NN ----------
  function getItemFromQuery() {
    const params = new URLSearchParams(window.location.search);
    const idx = params.get('item');
    if (!idx) return null;
    return thumbs.find(t => t.dataset.idx === idx) || null;
  }

  // ---------- Cambio de vídeo de fondo con crossfade GSAP ----------
  // Asignamos la nueva URL al <video> "back" y esperamos a `canplay` para no fade-in
  // hacia un vídeo aún sin frames. Antes del fade FORZAMOS que el back tenga z-index
  // superior: si no, según cuál de los dos <video> sea (DOM-antes o DOM-después), el
  // otro se le pondría delante y el fade ocurriría tapado.
  function swapVideo(newSrc, newPoster) {
    if (!newSrc || newSrc === currentVideoSrc) return;
    currentVideoSrc = newSrc;

    const showBack = () => {
      // Z-index: el back que vamos a fade-in tiene que estar EN FRENTE.
      back.style.zIndex  = 2;
      front.style.zIndex = 1;

      if (reduceMotion.matches) {
        front.classList.remove('is-front');
        back.classList.add('is-front');
        front.style.opacity = '';
        back.style.opacity  = '';
        front.pause();
        // En reduced-motion mantenemos el poster del back y NO reproducimos.
        [front, back] = [back, front];
        return;
      }

      gsap.to(back, {
        opacity: 1, duration: 0.55, ease: 'power2.out', overwrite: 'auto',
        onComplete: () => {
          back.classList.add('is-front');
          front.classList.remove('is-front');
          front.style.opacity = 0;
          // pausar el que sale para no consumir CPU con dos vídeos a la vez
          front.pause();
          // swap referencias
          [front, back] = [back, front];
          back.style.opacity = 0;
        }
      });
    };

    // Preparamos el back: poster (para que el frame previo sea la miniatura) + src + load.
    back.style.opacity = 0;
    back.pause();
    if (newPoster) back.setAttribute('poster', newPoster);
    back.src = newSrc;
    try { back.load(); } catch (e) { /* algunos navegadores pueden ignorar */ }

    const start = () => {
      if (!reduceMotion.matches) {
        back.play().catch(() => { /* autoplay bloqueado, sigue sin reproducirse */ });
      }
      showBack();
    };

    // readyState >= 2 (HAVE_CURRENT_DATA) ya garantiza primer frame disponible.
    if (back.readyState >= 2) {
      start();
    } else {
      back.addEventListener('canplay', function onReady() {
        back.removeEventListener('canplay', onReady);
        start();
      }, { once: true });
      // fallback si el vídeo nunca dispara canplay (red lenta o URL caída):
      // hacemos el swap igualmente tras 1.5s para que la UI no se quede colgada.
      setTimeout(() => {
        if (back.readyState < 2 && back.style.opacity === '0') start();
      }, 1500);
    }
  }

  // ---------- Shelf: el estado activo lo lleva CSS (escala + hover) ----------
  // GSAP no toca el `transform` de las miniaturas: si lo tocara, dejaría inline-styles
  // que ganarían a la regla CSS :hover. Aquí sólo añadimos/quitamos la clase .is-active.
  function setActiveThumb(target) {
    if (!target) return;
    const previous = thumbs.find(t => t.classList.contains('is-active'));
    if (previous === target) return;
    if (previous) previous.classList.remove('is-active');
    target.classList.add('is-active');
  }
  // Nota: el shelf está alineado a la izquierda y crece hacia la derecha. El primer
  // thumb nunca cambia de posición, así que la alineación del caption la hace CSS.

  // ---------- Cambio de texto del caption: fade-out → swap → fade-in ----------
  // Pasos:
  //   1) Todo el bloque desaparece a opacity 0 al mismo tiempo (sin stagger).
  //   2) Cuando ya no se ve nada, intercambiamos el textContent de las tres líneas.
  //   3) Aparece el nuevo texto con un fade-in al unísono.
  // Una única timeline asegura que el swap ocurre EXACTAMENTE cuando opacity = 0.
  function setCaptionText({ idx, label, by }) {
    if (captionIdx.textContent === '[ ' + idx + ' ]' &&
        captionLbl.textContent === label &&
        captionBy.textContent  === 'Featured by: ' + by) {
      return; // ya está
    }
    if (reduceMotion.matches) {
      captionIdx.textContent = '[ ' + idx + ' ]';
      captionLbl.textContent = label;
      captionBy.textContent  = 'Featured by: ' + by;
      return;
    }
    const parts = [captionIdx, captionLbl, captionBy];
    gsap.timeline({ overwrite: 'auto' })
      // 1) fade-out — overwrite: 'auto' cancela cualquier animación previa en curso
      .to(parts, { opacity: 0, duration: 0.25, ease: 'power1.in' })
      // 2) swap del texto exactamente al llegar a 0
      .add(() => {
        captionIdx.textContent = '[ ' + idx + ' ]';
        captionLbl.textContent = label;
        captionBy.textContent  = 'Featured by: ' + by;
      })
      // 3) fade-in del nuevo texto
      .to(parts, { opacity: 1, duration: 0.35, ease: 'power2.out' });
  }

  // ---------- Activación completa por índice: vídeo + shelf + caption ----------
  // Es la función central que llaman click, scroll y focus (Tab).
  // Es idempotente: si el item ya está activo, no vuelve a animar.
  function activateByIndex(i, opts) {
    const t = thumbs[i];
    if (!t) return;
    const wasActive = t.classList.contains('is-active');
    setActiveThumb(t);
    swapVideo(t.dataset.video, t.dataset.image);
    setCaptionText({ idx: t.dataset.idx, label: t.dataset.label, by: t.dataset.by });
    // Llevamos la miniatura activa al centro del shelf (sólo si no es por scroll de página).
    if (!wasActive && !(opts && opts.skipScrollIntoView)) {
      t.scrollIntoView({ behavior: 'smooth', block: 'nearest', inline: 'center' });
    }
  }

  // ---------- Click en una miniatura ----------
  thumbs.forEach((t, i) => {
    t.addEventListener('click', () => activateByIndex(i));
  });

  // ---------- Tab / foco de teclado: al recibir foco, activa el item ----------
  // Con `<button>`s, Tab navega de uno a otro de forma nativa. Al recibir foco,
  // dejamos que el item se active igual que si hubieras clicado.
  thumbs.forEach((t, i) => {
    t.addEventListener('focus', () => activateByIndex(i));
  });

  // También navegación por flechas izquierda/derecha cuando un thumb tiene el foco.
  root.querySelector('.bolsos-v2-detail_shelf').addEventListener('keydown', (e) => {
    if (e.key !== 'ArrowLeft' && e.key !== 'ArrowRight') return;
    const current = thumbs.findIndex(t => t === document.activeElement);
    if (current < 0) return;
    const next = e.key === 'ArrowRight'
      ? Math.min(thumbs.length - 1, current + 1)
      : Math.max(0, current - 1);
    e.preventDefault();
    thumbs[next].focus(); // dispara focus → activateByIndex
  });

  // ---------- Estado inicial ----------
  const startThumb = getItemFromQuery() || thumbs[0];
  const startIdx = thumbs.indexOf(startThumb);
  if (startIdx > 0) {
    activateByIndex(startIdx, { skipScrollIntoView: true });
  } else {
    // El primero ya viene pintado en HTML — sólo aseguro el active
    setActiveThumb(thumbs[0]);
  }

  // ---------- Scroll → AVANZA entre imágenes (vídeo + shelf + caption) ----------
  if (window.gsap && window.ScrollTrigger) {
    gsap.registerPlugin(ScrollTrigger);

    // El stage queda fijo (pin) durante el scroll de todos los scrollsteps.
    // `invalidateOnRefresh: true` → recomputa medidas al hacer refresh
    // (necesario para que el pin se adapte al cambiar la viewport).
    ScrollTrigger.create({
      trigger: '.bolsos-v2-detail_wrap',
      start: 'top top',
      end:   'bottom bottom',
      pin:   '.bolsos-v2-detail_stage',
      pinSpacing: false,
      invalidateOnRefresh: true
    });

    // Cada scrollstep activa su item al entrar en el centro de la viewport.
    // Se pasa skipScrollIntoView para no encadenar un scroll del shelf con el de la página.
    steps.forEach((step, i) => {
      ScrollTrigger.create({
        trigger: step,
        start: 'top center',
        end:   'bottom center',
        invalidateOnRefresh: true,
        onEnter:     () => activateByIndex(i, { skipScrollIntoView: true }),
        onEnterBack: () => activateByIndex(i, { skipScrollIntoView: true })
      });
    });

    // ScrollTrigger refresca solo en `resize` del window, pero en iframes que
    // cambian de tamaño (resize-bar del viewer) los listeners pueden no
    // dispararse. Lo forzamos también con ResizeObserver sobre el wrap y con
    // un fallback en `resize` del window con debounce.
    let resizeRaf = 0;
    const scheduleRefresh = () => {
      if (resizeRaf) cancelAnimationFrame(resizeRaf);
      resizeRaf = requestAnimationFrame(() => {
        ScrollTrigger.refresh();
        resizeRaf = 0;
      });
    };
    window.addEventListener('resize', scheduleRefresh);
    if ('ResizeObserver' in window) {
      new ResizeObserver(scheduleRefresh).observe(root);
    }
  }

  // ---------- prefers-reduced-motion ----------
  // El swap de imagen ya consulta reduceMotion.matches en cada llamada.
  // Aquí no hay que hacer nada extra (las imágenes son estáticas).

})();
</script>
{% endblock %}
